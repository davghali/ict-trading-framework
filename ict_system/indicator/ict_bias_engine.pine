// @version=6
// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  ICT BIAS ENGINE v2 — Multi-Layer Scoring                               ║
// ║  David Ghali x Claude                                                    ║
// ║                                                                          ║
// ║  5-LAYER BIAS SCORING per TF :                                           ║
// ║    1. Price vs Open        (+1 bull / -1 bear)                           ║
// ║    2. Candle direction     (close > open = bull)                         ║
// ║    3. Position in range    (upper half = bull / lower half = bear)       ║
// ║    4. Previous candle      (prev bullish close = bull bias carry)        ║
// ║    5. Structure break      (recent BOS up/down)                          ║
// ║                                                                          ║
// ║  Score +5/+3 → strong BULL · -5/-3 → strong BEAR · else NEUT             ║
// ║  Confidence = |score| / 5 × 100 %                                        ║
// ║                                                                          ║
// ║  OUTPUTS :                                                               ║
// ║    • Swing H/L (ta.pivothigh/pivotlow)                                   ║
// ║    • Bias W/D/H4/H1/M15 with confidence %                                ║
// ║    • PO3 phase per TF                                                    ║
// ║    • Opens per TF (step lines)                                           ║
// ║    • HUD compact : TF · BIAS · CONF% · PO3                               ║
// ╚══════════════════════════════════════════════════════════════════════════╝

indicator(
     title            = "ICT Bias Engine v2 — 5-Layer Scoring",
     shorttitle       = "ICT BIAS v2",
     overlay          = true,
     max_lines_count  = 500,
     max_labels_count = 500,
     max_boxes_count  = 100)

// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  INPUTS                                                                  ║
// ╚══════════════════════════════════════════════════════════════════════════╝

g_swing = "📐 Swings"
swing_len   = input.int(3, "Swing length (pivot lookback)",
     minval = 1, maxval = 20,
     group = g_swing,
     tooltip = "ICT default = 3. Higher = smoother but slower signals")
show_swings = input.bool(true, "Show swing H/L markers", group = g_swing)

g_bias = "🎯 Bias"
show_hud           = input.bool(true,  "Show HUD table",           group = g_bias)
min_conf_strong    = input.int(80, "Min confidence for STRONG bias (%)",
     minval = 40, maxval = 100, step = 10,
     group = g_bias,
     tooltip = "≥ 80% = STRONG BULL/BEAR · 60-80% = moderate · < 60% = NEUT")
min_conf_moderate  = input.int(60, "Min confidence for MODERATE bias (%)",
     minval = 40, maxval = 80, step = 10,
     group = g_bias)

g_opens = "📍 Opens"
show_w_open   = input.bool(true,  "Weekly Open",  group = g_opens)
show_d_open   = input.bool(true,  "Daily Open",   group = g_opens)
show_h4_open  = input.bool(true,  "H4 Open",      group = g_opens)
show_h1_open  = input.bool(true,  "H1 Open",      group = g_opens)
show_m15_open = input.bool(false, "M15 Open",     group = g_opens)

g_style = "🎨 Style"
col_bull   = input.color(color.new(#10B981, 0), "BULL",   group = g_style)
col_bear   = input.color(color.new(#EF4444, 0), "BEAR",   group = g_style)
col_neut   = input.color(color.new(#94A3B8, 0), "NEUT",   group = g_style)
col_accum  = input.color(color.new(#FBBF24, 0), "ACCUM",  group = g_style)
col_manip  = input.color(color.new(#EC4899, 0), "MANIP",  group = g_style)

// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  SWING POINTS (Pine official, no repaint)                                ║
// ╚══════════════════════════════════════════════════════════════════════════╝

swing_h_val = ta.pivothigh(high, swing_len, swing_len)
swing_l_val = ta.pivotlow(low,   swing_len, swing_len)

plotshape(show_swings and not na(swing_h_val) ? swing_h_val : na,
     title = "Swing H", style = shape.triangledown, location = location.absolute,
     color = color.new(col_bear, 30), size = size.tiny, offset = -swing_len)

plotshape(show_swings and not na(swing_l_val) ? swing_l_val : na,
     title = "Swing L", style = shape.triangleup, location = location.absolute,
     color = color.new(col_bull, 30), size = size.tiny, offset = -swing_len)

// Track last 2 swings for BOS detection
var float last_sh = na
var float prev_sh = na
var float last_sl = na
var float prev_sl = na

if not na(swing_h_val)
    prev_sh := last_sh
    last_sh := swing_h_val
if not na(swing_l_val)
    prev_sl := last_sl
    last_sl := swing_l_val

// Current TF BOS detection (for layer 5 of bias)
bos_bull_ltf = not na(last_sh) and close > last_sh and close[1] <= last_sh
bos_bear_ltf = not na(last_sl) and close < last_sl and close[1] >= last_sl

var int bos_dir = 0   // 1 = last BOS bull, -1 = last BOS bear, 0 = none yet
if bos_bull_ltf
    bos_dir := 1
if bos_bear_ltf
    bos_dir := -1

// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  FETCH HTF DATA (single security call per TF — efficient)                ║
// ║  We fetch : open, high, low, close, prev_close, and structure signal     ║
// ╚══════════════════════════════════════════════════════════════════════════╝

// Per TF : current candle OHLC + previous close + approximation of structure
f_tf_data(simple string tf) =>
    _o  = request.security(syminfo.tickerid, tf, open,     lookahead = barmerge.lookahead_off)
    _h  = request.security(syminfo.tickerid, tf, high,     lookahead = barmerge.lookahead_off)
    _l  = request.security(syminfo.tickerid, tf, low,      lookahead = barmerge.lookahead_off)
    _c  = request.security(syminfo.tickerid, tf, close,    lookahead = barmerge.lookahead_off)
    _pc = request.security(syminfo.tickerid, tf, close[1], lookahead = barmerge.lookahead_off)
    _po = request.security(syminfo.tickerid, tf, open[1],  lookahead = barmerge.lookahead_off)
    [_o, _h, _l, _c, _pc, _po]

[w_o, w_h, w_l, w_c, w_pc, w_po]             = f_tf_data("W")
[d_o, d_h, d_l, d_c, d_pc, d_po]             = f_tf_data("D")
[h4_o, h4_h, h4_l, h4_c, h4_pc, h4_po]       = f_tf_data("240")
[h1_o, h1_h, h1_l, h1_c, h1_pc, h1_po]       = f_tf_data("60")
[m15_o, m15_h, m15_l, m15_c, m15_pc, m15_po] = f_tf_data("15")

// Fetch current price for vs-open comparison
cur_price = close

// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  5-LAYER BIAS SCORING                                                    ║
// ║                                                                          ║
// ║  Returns [score, bias_str, confidence_pct]                               ║
// ║                                                                          ║
// ║  Layer 1 : price vs open (CURRENT PRICE, not close)                     ║
// ║  Layer 2 : candle direction (close vs open)                              ║
// ║  Layer 3 : position in range (upper/lower half)                          ║
// ║  Layer 4 : previous candle direction (prev_close vs prev_open)           ║
// ║  Layer 5 : recent structure break (HTF proxy : higher high vs lower low) ║
// ║                                                                          ║
// ║  Each layer contributes +1 (bull) / -1 (bear) / 0 (neut).                ║
// ║  Total range : -5 to +5.                                                 ║
// ║  Confidence : |score| / 5 × 100 %                                        ║
// ║  Bias       : BULL if score ≥ 3, BEAR if ≤ -3, else NEUT                 ║
// ╚══════════════════════════════════════════════════════════════════════════╝

f_score(float o, float h, float l, float c, float pc, float po, float cp,
        simple int conf_strong, simple int conf_moderate) =>

    // Layer 1 : current price vs current candle open
    _l1 = cp > o ? 1 : cp < o ? -1 : 0

    // Layer 2 : candle close vs open (body direction)
    _l2 = c > o ? 1 : c < o ? -1 : 0

    // Layer 3 : position in range (closer to high = bull, closer to low = bear)
    _range = h - l
    _mid   = (h + l) / 2
    _l3 = _range > 0 and cp > _mid ? 1 : _range > 0 and cp < _mid ? -1 : 0

    // Layer 4 : previous candle direction
    _l4 = pc > po ? 1 : pc < po ? -1 : 0

    // Layer 5 : HTF structure proxy — is current high above previous high?
    //           (a simple HH/LL check based on candle extremes)
    _l5 = h > pc and l > po ? 1 : h < pc and l < po ? -1 : 0

    _score = _l1 + _l2 + _l3 + _l4 + _l5
    _abs_score = math.abs(_score)
    _conf = _abs_score * 20   // each layer = 20% → max 100%

    string _bias = "NEUT"
    if _score >= 3 and _conf >= conf_moderate
        _bias := _conf >= conf_strong ? "BULL+" : "BULL"
    if _score <= -3 and _conf >= conf_moderate
        _bias := _conf >= conf_strong ? "BEAR+" : "BEAR"

    [_score, _bias, _conf]

[score_w,   bias_w,   conf_w]   = f_score(w_o,   w_h,   w_l,   w_c,   w_pc,   w_po,   cur_price, min_conf_strong, min_conf_moderate)
[score_d,   bias_d,   conf_d]   = f_score(d_o,   d_h,   d_l,   d_c,   d_pc,   d_po,   cur_price, min_conf_strong, min_conf_moderate)
[score_h4,  bias_h4,  conf_h4]  = f_score(h4_o,  h4_h,  h4_l,  h4_c,  h4_pc,  h4_po,  cur_price, min_conf_strong, min_conf_moderate)
[score_h1,  bias_h1,  conf_h1]  = f_score(h1_o,  h1_h,  h1_l,  h1_c,  h1_pc,  h1_po,  cur_price, min_conf_strong, min_conf_moderate)
[score_m15, bias_m15, conf_m15] = f_score(m15_o, m15_h, m15_l, m15_c, m15_pc, m15_po, cur_price, min_conf_strong, min_conf_moderate)

// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  PO3 PHASE per TF                                                        ║
// ╚══════════════════════════════════════════════════════════════════════════╝

f_po3(float o, float h, float l, float c) =>
    _range = h - l
    _body  = math.abs(c - o)
    _uw    = h - math.max(o, c)
    _lw    = math.min(o, c) - l
    string _phase = "—"
    if _range == 0
        _phase := "—"
    else if _body / _range < 0.2
        _phase := "ACCUM"
    else if c > o and _lw > _uw * 1.3
        _phase := "DISTR↑"
    else if c < o and _uw > _lw * 1.3
        _phase := "DISTR↓"
    else if _uw > _body and _lw > _body
        _phase := "MANIP"
    else if c > o
        _phase := "DISTR↑"
    else if c < o
        _phase := "DISTR↓"
    _phase

po3_w   = f_po3(w_o,   w_h,   w_l,   w_c)
po3_d   = f_po3(d_o,   d_h,   d_l,   d_c)
po3_h4  = f_po3(h4_o,  h4_h,  h4_l,  h4_c)
po3_h1  = f_po3(h1_o,  h1_h,  h1_l,  h1_c)
po3_m15 = f_po3(m15_o, m15_h, m15_l, m15_c)

// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  PLOT OPENS (step lines)                                                 ║
// ╚══════════════════════════════════════════════════════════════════════════╝

plot(show_w_open   ? w_o   : na, title = "W Open",   color = color.new(#9C27B0, 0), linewidth = 3, style = plot.style_linebr)
plot(show_d_open   ? d_o   : na, title = "D Open",   color = color.new(#FF9800, 0), linewidth = 2, style = plot.style_linebr)
plot(show_h4_open  ? h4_o  : na, title = "H4 Open",  color = color.new(#2196F3, 0), linewidth = 1, style = plot.style_linebr)
plot(show_h1_open  ? h1_o  : na, title = "H1 Open",  color = color.new(#4CAF50, 0), linewidth = 1, style = plot.style_linebr)
plot(show_m15_open ? m15_o : na, title = "M15 Open", color = color.new(#9E9E9E, 0), linewidth = 1, style = plot.style_linebr)

// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  HUD TABLE                                                               ║
// ╚══════════════════════════════════════════════════════════════════════════╝

f_bias_col(string b) =>
    b == "BULL+" ? col_bull :
     b == "BULL"  ? color.new(col_bull, 30) :
     b == "BEAR+" ? col_bear :
     b == "BEAR"  ? color.new(col_bear, 30) :
     col_neut

f_po3_col(string p) =>
    p == "ACCUM"  ? col_accum :
     p == "MANIP"  ? col_manip :
     p == "DISTR↑" ? col_bull :
     p == "DISTR↓" ? col_bear :
     col_neut

f_conf_txt(int c) =>
    str.tostring(c) + "%"

var table hud = table.new(
     position     = position.top_right,
     columns      = 4,
     rows         = 8,
     bgcolor      = color.new(#0F172A, 0),
     border_color = color.new(#FFD700, 40),
     border_width = 1,
     frame_color  = color.new(#FFD700, 20),
     frame_width  = 2)

if show_hud and barstate.islast
    // Header
    table.cell(hud, 0, 0, "TF",    text_color = color.white, text_size = size.small, bgcolor = color.new(#1E293B, 0))
    table.cell(hud, 1, 0, "BIAS",  text_color = color.white, text_size = size.small, bgcolor = color.new(#1E293B, 0))
    table.cell(hud, 2, 0, "CONF",  text_color = color.white, text_size = size.small, bgcolor = color.new(#1E293B, 0))
    table.cell(hud, 3, 0, "PO3",   text_color = color.white, text_size = size.small, bgcolor = color.new(#1E293B, 0))

    // Row W
    table.cell(hud, 0, 1, "W",    text_color = color.new(#94A3B8, 10), text_size = size.tiny)
    table.cell(hud, 1, 1, bias_w, text_color = f_bias_col(bias_w),     text_size = size.tiny)
    table.cell(hud, 2, 1, f_conf_txt(conf_w), text_color = color.white, text_size = size.tiny)
    table.cell(hud, 3, 1, po3_w,  text_color = f_po3_col(po3_w),       text_size = size.tiny)

    // Row D
    table.cell(hud, 0, 2, "D",    text_color = color.new(#94A3B8, 10), text_size = size.tiny)
    table.cell(hud, 1, 2, bias_d, text_color = f_bias_col(bias_d),     text_size = size.tiny)
    table.cell(hud, 2, 2, f_conf_txt(conf_d), text_color = color.white, text_size = size.tiny)
    table.cell(hud, 3, 2, po3_d,  text_color = f_po3_col(po3_d),       text_size = size.tiny)

    // Row H4
    table.cell(hud, 0, 3, "H4",   text_color = color.new(#94A3B8, 10), text_size = size.tiny)
    table.cell(hud, 1, 3, bias_h4, text_color = f_bias_col(bias_h4),   text_size = size.tiny)
    table.cell(hud, 2, 3, f_conf_txt(conf_h4), text_color = color.white, text_size = size.tiny)
    table.cell(hud, 3, 3, po3_h4,  text_color = f_po3_col(po3_h4),     text_size = size.tiny)

    // Row H1
    table.cell(hud, 0, 4, "H1",   text_color = color.new(#94A3B8, 10), text_size = size.tiny)
    table.cell(hud, 1, 4, bias_h1, text_color = f_bias_col(bias_h1),   text_size = size.tiny)
    table.cell(hud, 2, 4, f_conf_txt(conf_h1), text_color = color.white, text_size = size.tiny)
    table.cell(hud, 3, 4, po3_h1,  text_color = f_po3_col(po3_h1),     text_size = size.tiny)

    // Row M15
    table.cell(hud, 0, 5, "M15",  text_color = color.new(#94A3B8, 10), text_size = size.tiny)
    table.cell(hud, 1, 5, bias_m15, text_color = f_bias_col(bias_m15), text_size = size.tiny)
    table.cell(hud, 2, 5, f_conf_txt(conf_m15), text_color = color.white, text_size = size.tiny)
    table.cell(hud, 3, 5, po3_m15,  text_color = f_po3_col(po3_m15),   text_size = size.tiny)

    // Alignment row
    _all_bull = str.contains(bias_w, "BULL") and str.contains(bias_d, "BULL") and str.contains(bias_h4, "BULL")
    _all_bear = str.contains(bias_w, "BEAR") and str.contains(bias_d, "BEAR") and str.contains(bias_h4, "BEAR")
    _align_txt = _all_bull ? "🟢 ALIGNED BULL" : _all_bear ? "🔴 ALIGNED BEAR" : "⚠️ MIXED"
    _align_col = _all_bull ? col_bull : _all_bear ? col_bear : col_neut
    _avg_conf  = math.round((conf_w + conf_d + conf_h4) / 3)

    table.cell(hud, 0, 6, "ALIGN W+D+H4", text_color = color.white, text_size = size.tiny, bgcolor = color.new(#1E293B, 0))
    table.cell(hud, 1, 6, _align_txt,     text_color = _align_col,  text_size = size.tiny, bgcolor = color.new(#1E293B, 0))
    table.cell(hud, 2, 6, f_conf_txt(_avg_conf), text_color = color.white, text_size = size.tiny, bgcolor = color.new(#1E293B, 0))
    table.cell(hud, 3, 6, "avg", text_color = color.new(#94A3B8, 20), text_size = size.tiny, bgcolor = color.new(#1E293B, 0))

    // Current price vs opens quick summary
    _vs_w   = cur_price > w_o   ? "↑" : cur_price < w_o   ? "↓" : "="
    _vs_d   = cur_price > d_o   ? "↑" : cur_price < d_o   ? "↓" : "="
    _vs_h4  = cur_price > h4_o  ? "↑" : cur_price < h4_o  ? "↓" : "="
    _vs_h1  = cur_price > h1_o  ? "↑" : cur_price < h1_o  ? "↓" : "="
    _vs_m15 = cur_price > m15_o ? "↑" : cur_price < m15_o ? "↓" : "="

    table.cell(hud, 0, 7, "vs Open", text_color = color.white, text_size = size.tiny, bgcolor = color.new(#1E293B, 0))
    table.cell(hud, 1, 7, _vs_w + _vs_d + _vs_h4 + _vs_h1 + _vs_m15, text_color = color.white, text_size = size.tiny, bgcolor = color.new(#1E293B, 0))
    table.cell(hud, 2, 7, "", bgcolor = color.new(#1E293B, 0))
    table.cell(hud, 3, 7, "W·D·H4·H1·M15", text_color = color.new(#94A3B8, 20), text_size = size.tiny, bgcolor = color.new(#1E293B, 0))

// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  ALERTS                                                                  ║
// ╚══════════════════════════════════════════════════════════════════════════╝

_strong_bull_align = bias_w == "BULL+" and bias_d == "BULL+" and bias_h4 == "BULL+"
_strong_bear_align = bias_w == "BEAR+" and bias_d == "BEAR+" and bias_h4 == "BEAR+"

alertcondition(_strong_bull_align and not _strong_bull_align[1],
     "STRONG BULL alignment W+D+H4",
     "ICT Bias : STRONG BULL alignment on {{ticker}} (W+D+H4 all 80%+)")

alertcondition(_strong_bear_align and not _strong_bear_align[1],
     "STRONG BEAR alignment W+D+H4",
     "ICT Bias : STRONG BEAR alignment on {{ticker}} (W+D+H4 all 80%+)")

// End of ICT Bias Engine v2 ──────────────────────────────────────────────────
