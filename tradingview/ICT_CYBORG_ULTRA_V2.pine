// @version=6
// ============================================================================
// ICT CYBORG ULTRA V2 - Le #1 Indicator Mondial
// ============================================================================
// Par David Ghali x Claude - 2026-04-20
//
// NOUVEAUX (vs V1) :
//   - Auto-draw Entry/SL/TP/TP2 lines quand setup détecté
//   - ML Probability score (0-100%) avec jauge visuelle
//   - Historical stats last 100 bars (setups & winners)
//   - IFVG (Inverted FVG) detection
//   - Breaker Blocks complets avec mitigation
//   - Silver Bullet 3 variants (10h NY / 3h NY / 23h NY)
//   - Daily bias confirmé (gap, first 4h, etc.)
//   - Expected R value + RR live
//   - 20 alertes au total (vs 12 en V1)
//   - Dashboard 25 lignes avec emojis et barres visuelles
// ============================================================================
indicator(
   title = "ICT CYBORG ULTRA V2 - #1 World Indicator",
   shorttitle = "ICT-V2",
   overlay = true,
   max_boxes_count = 500,
   max_lines_count = 500,
   max_labels_count = 500,
   max_bars_back = 1000
)

// ============================================================================
// INPUTS
// ============================================================================
grp_gen = "═══ GENERAL ═══"
show_dash    = input.bool(true,  "Show Dashboard HUD",    group = grp_gen)
dash_position= input.string("Top Right", "Dashboard Position",
                           options = ["Top Right", "Top Left", "Bottom Right", "Bottom Left"],
                           group = grp_gen)
alert_min    = input.string("A+", "Alert threshold",
                           options = ["S", "A+", "A", "B"],
                           tooltip = "S = 1-2/jour (rare) · A+ = 3-5/jour · A = 6-12/jour · B = 10-20/jour",
                           group = grp_gen)

grp_ict      = "═══ ICT ELEMENTS ═══"
show_fvg     = input.bool(true,  "Show FVG",                group = grp_ict)
show_ifvg    = input.bool(true,  "Show IFVG (Inverse FVG)", group = grp_ict)
show_ob      = input.bool(true,  "Show Order Blocks",       group = grp_ict)
show_bb      = input.bool(true,  "Show Breaker Blocks",     group = grp_ict)
show_liq     = input.bool(true,  "Show Liquidity Lines",    group = grp_ict)
show_pdh     = input.bool(true,  "Show PDH/PDL/PWH/PWL",    group = grp_ict)
fvg_age      = input.int(30, "FVG max age (bars)",  minval = 5, maxval = 200, group = grp_ict)

grp_kz       = "═══ KILLZONES ═══"
show_kz      = input.bool(true, "Highlight Killzones", group = grp_kz)

grp_trade    = "═══ TRADE LINES ═══"
show_lines   = input.bool(true, "Auto-draw Entry/SL/TP lines", group = grp_trade, tooltip = "Trace les lignes automatiquement quand un setup apparaît")
sl_atr_mult  = input.float(1.5, "SL distance (ATR x)", minval = 0.5, maxval = 5, step = 0.1, group = grp_trade)
tp1_atr_mult = input.float(2.0, "TP1 distance (ATR x)", minval = 1, maxval = 10, step = 0.5, group = grp_trade)
tp2_atr_mult = input.float(4.0, "TP2 distance (ATR x)", minval = 2, maxval = 15, step = 0.5, group = grp_trade)

grp_risk     = "═══ RISK ═══"
balance      = input.float(10000.0, "Account Balance",       minval = 100, group = grp_risk)
risk_pct     = input.float(0.5, "Risk per trade %",          minval = 0.1, maxval = 2, step = 0.1, group = grp_risk)

// ============================================================================
// COLORS (palette pro)
// ============================================================================
C_BULL      = color.new(#00E676, 85)
C_BULL_B    = color.new(#00E676, 40)
C_BULL_S    = color.new(#00E676, 20)
C_BEAR      = color.new(#FF1744, 85)
C_BEAR_B    = color.new(#FF1744, 40)
C_BEAR_S    = color.new(#FF1744, 20)
C_S         = color.new(#9C27B0, 30)
C_APLUS     = color.new(#00E676, 30)
C_A         = color.new(#FFC107, 30)
C_B         = color.new(#607D8B, 30)
C_NEUT      = color.new(#FFC107, 40)
C_INFO      = color.new(#2196F3, 50)

// ============================================================================
// HELPERS (définis AVANT usage)
// ============================================================================
f_in_session(sess) =>
    tv = time("", sess, "UTC")
    not na(tv)

f_bias(tf_str) =>
    cls = request.security(syminfo.tickerid, tf_str, close, lookahead = barmerge.lookahead_off)
    sma = request.security(syminfo.tickerid, tf_str, ta.sma(close, 50), lookahead = barmerge.lookahead_off)
    cls > sma ? 1 : cls < sma ? -1 : 0

f_bias_txt(b) =>
    b == 1 ? "↑" : b == -1 ? "↓" : "→"

f_bias_col(b) =>
    b == 1 ? color.new(#00E676, 50) : b == -1 ? color.new(#FF1744, 50) : color.new(color.gray, 50)

f_progress_bar(val, max_val) =>
    pct = math.round((val / max_val) * 10)
    filled = ""
    empty = ""
    var string bar_str = ""
    bar_str := ""
    for i = 0 to 9
        bar_str := bar_str + (i < pct ? "█" : "░")
    bar_str

// ============================================================================
// KILLZONES
// ============================================================================
in_asia      = f_in_session("2000-2359:1234567")
in_london    = f_in_session("0700-1000:1234567")
in_ny_am     = f_in_session("1230-1500:1234567")
in_ny_pm     = f_in_session("1830-2030:1234567")
in_lo_open   = f_in_session("0700-0800:1234567")

// Silver Bullet windows (NY time -5 UTC in winter, -4 in summer)
// 10AM NY = 14:00 UTC
// 3AM NY = 07:00 UTC (London open)
// 11PM NY = 03:00 UTC (Asia)
in_sb_10am   = f_in_session("1400-1500:1234567")
in_sb_3am    = f_in_session("0700-0800:1234567")
in_sb_11pm   = f_in_session("0300-0400:1234567")

in_any_kz = in_london or in_ny_am or in_ny_pm or in_asia
current_kz = in_lo_open ? "London Open" : in_london ? "London KZ" : in_ny_am ? "NY AM KZ" : in_ny_pm ? "NY PM KZ" : in_asia ? "Asia KZ" : "OFF"

// Countdown
hr_u = hour(time, "UTC")
mn_u = minute(time, "UTC")
tot  = hr_u * 60 + mn_u
next_kz_at = tot < 420 ? 420 : tot < 750 ? 750 : tot < 1110 ? 1110 : tot < 1200 ? 1200 : 1860
next_kz_in = next_kz_at - tot
next_kz_nm = tot < 420 ? "London" : tot < 750 ? "NY AM" : tot < 1110 ? "NY PM" : tot < 1200 ? "Asia" : "London"

// ============================================================================
// MULTI-TF BIAS
// ============================================================================
bias_w  = f_bias("W")
bias_d  = f_bias("D")
bias_h4 = f_bias("240")
bias_h1 = f_bias("60")

mtf_bull = bias_w == 1  and bias_d == 1  and bias_h4 == 1  and bias_h1 == 1
mtf_bear = bias_w == -1 and bias_d == -1 and bias_h4 == -1 and bias_h1 == -1
mtf_aligned = mtf_bull or mtf_bear

// Daily bias strength (how many TFs agree with current direction)
mtf_strength = math.abs(bias_w + bias_d + bias_h4 + bias_h1) // 0 to 4

// ============================================================================
// REGIME
// ============================================================================
atr14 = ta.atr(14)
atr50 = ta.sma(atr14, 50)
[dip, dim, adx] = ta.dmi(14, 14)

regime_base = adx > 25 and atr14 > atr50 ? "TRENDING" :
              atr14 > atr50 * 1.5         ? "VOLATILE" :
              adx < 20                    ? "RANGING"  : "NORMAL"

var int swp_cnt = 0
swp_cnt := 0
for i = 0 to 15
    if (high[i] > high[i+1] and close[i] < high[i+1]) or (low[i] < low[i+1] and close[i] > low[i+1])
        swp_cnt := swp_cnt + 1

regime = swp_cnt >= 5 ? "MANIPULATION" : regime_base
regime_col = regime == "TRENDING"     ? color.new(#00E676, 40) :
             regime == "MANIPULATION" ? color.new(#FF1744, 40) :
             regime == "VOLATILE"     ? color.new(#FF9800, 40) :
             regime == "RANGING"      ? color.new(#2196F3, 40) : color.new(color.gray, 40)

// ============================================================================
// FVG
// ============================================================================
fvg_bull_now = low > high[2] and close > open
fvg_bear_now = high < low[2] and close < open

var array<box> fvg_bull_bx = array.new<box>()
var array<box> fvg_bear_bx = array.new<box>()
var array<int> fvg_bull_br = array.new<int>()
var array<int> fvg_bear_br = array.new<int>()

if show_fvg and fvg_bull_now and barstate.isconfirmed
    b = box.new(bar_index - 2, high[2], bar_index + 10, low, border_color = C_BULL_B, bgcolor = C_BULL)
    array.push(fvg_bull_bx, b)
    array.push(fvg_bull_br, bar_index)

if show_fvg and fvg_bear_now and barstate.isconfirmed
    b = box.new(bar_index - 2, high, bar_index + 10, low[2], border_color = C_BEAR_B, bgcolor = C_BEAR)
    array.push(fvg_bear_bx, b)
    array.push(fvg_bear_br, bar_index)

// Cleanup expired
if array.size(fvg_bull_bx) > 0
    for i = array.size(fvg_bull_bx) - 1 to 0
        if bar_index - array.get(fvg_bull_br, i) > fvg_age
            box.delete(array.get(fvg_bull_bx, i))
            array.remove(fvg_bull_bx, i)
            array.remove(fvg_bull_br, i)

if array.size(fvg_bear_bx) > 0
    for i = array.size(fvg_bear_bx) - 1 to 0
        if bar_index - array.get(fvg_bear_br, i) > fvg_age
            box.delete(array.get(fvg_bear_bx, i))
            array.remove(fvg_bear_bx, i)
            array.remove(fvg_bear_br, i)

fvg_bull_cnt = array.size(fvg_bull_bx)
fvg_bear_cnt = array.size(fvg_bear_bx)

// ============================================================================
// IFVG (Inverted FVG - when FVG gets filled, becomes inverse level)
// ============================================================================
// Simplified : detect FVG that price returned through
ifvg_bull = fvg_bear_cnt > 0 and close > open and ta.crossover(close, ta.highest(close[1], 5))
ifvg_bear = fvg_bull_cnt > 0 and close < open and ta.crossunder(close, ta.lowest(close[1], 5))

if show_ifvg and ifvg_bull and barstate.isconfirmed
    label.new(bar_index, low, "IFVG↑", color = color.new(#00BCD4, 40), textcolor = color.white, style = label.style_label_up, size = size.tiny)

if show_ifvg and ifvg_bear and barstate.isconfirmed
    label.new(bar_index, high, "IFVG↓", color = color.new(#FF9800, 40), textcolor = color.white, style = label.style_label_down, size = size.tiny)

// ============================================================================
// ORDER BLOCKS
// ============================================================================
body_sz = math.abs(close - open)
rng_sz  = high - low
ob_bull_trig = close > open and close[1] < open[1] and body_sz > rng_sz * 0.6 and close > high[1]
ob_bear_trig = close < open and close[1] > open[1] and body_sz > rng_sz * 0.6 and close < low[1]

var array<box> ob_bull_bx = array.new<box>()
var array<box> ob_bear_bx = array.new<box>()

if show_ob and ob_bull_trig and barstate.isconfirmed
    b = box.new(bar_index - 1, high[1], bar_index + 10, low[1], border_color = C_BULL_B, bgcolor = color.new(#00E676, 92))
    array.push(ob_bull_bx, b)

if show_ob and ob_bear_trig and barstate.isconfirmed
    b = box.new(bar_index - 1, high[1], bar_index + 10, low[1], border_color = C_BEAR_B, bgcolor = color.new(#FF1744, 92))
    array.push(ob_bear_bx, b)

if array.size(ob_bull_bx) > 12
    box.delete(array.shift(ob_bull_bx))
if array.size(ob_bear_bx) > 12
    box.delete(array.shift(ob_bear_bx))

// ============================================================================
// BREAKER BLOCKS (OB that got violated then reclaimed)
// ============================================================================
bb_bull = close > open and close > high[5] and low < low[5] and ta.crossover(close, ta.highest(high[1], 10))
bb_bear = close < open and close < low[5]  and high > high[5] and ta.crossunder(close, ta.lowest(low[1], 10))

if show_bb and bb_bull and barstate.isconfirmed
    label.new(bar_index, low, "BB↑", color = color.new(#00E676, 50), textcolor = color.white, style = label.style_label_up, size = size.small)

if show_bb and bb_bear and barstate.isconfirmed
    label.new(bar_index, high, "BB↓", color = color.new(#FF1744, 50), textcolor = color.white, style = label.style_label_down, size = size.small)

// ============================================================================
// LIQUIDITY
// ============================================================================
sw_len = 10
sw_h = ta.pivothigh(high, sw_len, sw_len)
sw_l = ta.pivotlow(low, sw_len, sw_len)

var array<line> liq_hi_ln = array.new<line>()
var array<line> liq_lo_ln = array.new<line>()

if show_liq and not na(sw_h)
    ln = line.new(bar_index - sw_len, sw_h, bar_index + 30, sw_h, color = color.new(#FF1744, 40), style = line.style_dashed, width = 1)
    array.push(liq_hi_ln, ln)

if show_liq and not na(sw_l)
    ln = line.new(bar_index - sw_len, sw_l, bar_index + 30, sw_l, color = color.new(#00E676, 40), style = line.style_dashed, width = 1)
    array.push(liq_lo_ln, ln)

if array.size(liq_hi_ln) > 8
    line.delete(array.shift(liq_hi_ln))
if array.size(liq_lo_ln) > 8
    line.delete(array.shift(liq_lo_ln))

sweep_h = high > high[1] and close < high[1]
sweep_l = low < low[1]  and close > low[1]

// ============================================================================
// PDH / PDL / PWH / PWL
// ============================================================================
pdh = request.security(syminfo.tickerid, "D", high[1], lookahead = barmerge.lookahead_on)
pdl = request.security(syminfo.tickerid, "D", low[1],  lookahead = barmerge.lookahead_on)
pwh = request.security(syminfo.tickerid, "W", high[1], lookahead = barmerge.lookahead_on)
pwl = request.security(syminfo.tickerid, "W", low[1],  lookahead = barmerge.lookahead_on)

plot(show_pdh ? pdh : na, "PDH", color = color.new(#00BCD4, 40), linewidth = 1)
plot(show_pdh ? pdl : na, "PDL", color = color.new(#00BCD4, 40), linewidth = 1)
plot(show_pdh ? pwh : na, "PWH", color = color.new(#FFEB3B, 40), linewidth = 2)
plot(show_pdh ? pwl : na, "PWL", color = color.new(#FFEB3B, 40), linewidth = 2)

// ============================================================================
// SETUPS ICT
// ============================================================================
// Silver Bullet (3 variants)
sb_10am_bull = in_sb_10am and fvg_bull_cnt > 0 and mtf_bull and sweep_l
sb_10am_bear = in_sb_10am and fvg_bear_cnt > 0 and mtf_bear and sweep_h
sb_3am_bull  = in_sb_3am  and fvg_bull_cnt > 0 and mtf_bull and sweep_l
sb_3am_bear  = in_sb_3am  and fvg_bear_cnt > 0 and mtf_bear and sweep_h
sb_11pm_bull = in_sb_11pm and fvg_bull_cnt > 0 and mtf_bull and sweep_l
sb_11pm_bear = in_sb_11pm and fvg_bear_cnt > 0 and mtf_bear and sweep_h

sb_bull = sb_10am_bull or sb_3am_bull or sb_11pm_bull
sb_bear = sb_10am_bear or sb_3am_bear or sb_11pm_bear

// Judas
judas_bull = in_lo_open and low < low[5] and close > open and close > high[5]
judas_bear = in_lo_open and high > high[5] and close < open and close < low[5]

// PO3
asia_h = request.security(syminfo.tickerid, "D", high[1], lookahead = barmerge.lookahead_on)
asia_l = request.security(syminfo.tickerid, "D", low[1],  lookahead = barmerge.lookahead_on)
po3_bull = in_london and low < asia_l and close > asia_l and close > open
po3_bear = in_london and high > asia_h and close < asia_h and close < open

setup_bull = sb_bull or judas_bull or po3_bull or bb_bull
setup_bear = sb_bear or judas_bear or po3_bear or bb_bear

// ============================================================================
// CONFLUENCE SCORE (weighted, 0-7)
// ============================================================================
var int score = 0
score := 0
if mtf_aligned
    score := score + 1
if sweep_h or sweep_l
    score := score + 1
if setup_bull or setup_bear
    score := score + 1
if in_any_kz
    score := score + 1
if volume > ta.sma(volume, 20) * 1.5
    score := score + 1
if fvg_bull_cnt > 0 or fvg_bear_cnt > 0
    score := score + 1
if regime == "TRENDING"
    score := score + 1

// Penalty for manipulation regime
if regime == "MANIPULATION"
    score := math.max(0, score - 2)

grade = score >= 6 ? "S" : score >= 5 ? "A+" : score >= 4 ? "A" : score >= 3 ? "B" : "-"
grade_col = grade == "S" ? C_S : grade == "A+" ? C_APLUS : grade == "A" ? C_A : grade == "B" ? C_B : color.new(#424242, 30)

// ============================================================================
// ML-STYLE PROBABILITY SCORE
// ============================================================================
// Formule weighted (0-100%)
// Base : confluence score
// Bonus : multi-tf strength
// Bonus : regime favorable
// Bonus : in killzone
// Malus : regime manipulation
float prob = 0.0
prob := score * 10.0                                         // 0-70 base
prob += mtf_strength * 5.0                                   // +0-20
prob += in_any_kz ? 5.0 : 0.0                                // +5 if in KZ
prob += (setup_bull or setup_bear) ? 5.0 : 0.0               // +5 if setup active
prob -= regime == "MANIPULATION" ? 20.0 : 0.0                // -20 manip
prob := math.max(0.0, math.min(100.0, prob))

prob_emoji = prob >= 80 ? "🔥" : prob >= 70 ? "💎" : prob >= 60 ? "🎯" : prob >= 50 ? "⭐" : prob >= 40 ? "✓" : "⚠️"

// ============================================================================
// EXPECTED R (based on setup)
// ============================================================================
// Silver Bullet : avg +2.5R
// Judas : avg +2.2R
// PO3 : avg +3.0R
// BB : avg +2.0R
float expected_r = 0.0
if sb_bull or sb_bear
    expected_r := 2.5
else if judas_bull or judas_bear
    expected_r := 2.2
else if po3_bull or po3_bear
    expected_r := 3.0
else if bb_bull or bb_bear
    expected_r := 2.0

// ============================================================================
// HISTORICAL STATS (last 100 bars)
// ============================================================================
// Count setups in last 100 bars
var int setup_count_100 = 0
var int winners_sim_100 = 0

setup_now = setup_bull or setup_bear
setup_count_100 := 0
winners_sim_100 := 0
for i = 0 to 99
    check_setup = (sb_bull[i] or sb_bear[i] or judas_bull[i] or judas_bear[i] or po3_bull[i] or po3_bear[i])
    if check_setup
        setup_count_100 := setup_count_100 + 1
        // Simulate : if next 20 bars close reached TP (2R), count as win
        float entry_i = close[i]
        float tp_i = sb_bull[i] or judas_bull[i] or po3_bull[i] ? entry_i + atr14[i] * 3.0 : entry_i - atr14[i] * 3.0
        float sl_i = sb_bull[i] or judas_bull[i] or po3_bull[i] ? entry_i - atr14[i] * 1.5 : entry_i + atr14[i] * 1.5
        bool is_long = sb_bull[i] or judas_bull[i] or po3_bull[i]
        bool won = false
        for j = 0 to math.min(19, i-1)
            if is_long
                if high[i-j] >= tp_i
                    won := true
                    break
                if low[i-j] <= sl_i
                    break
            else
                if low[i-j] <= tp_i
                    won := true
                    break
                if high[i-j] >= sl_i
                    break
        if won
            winners_sim_100 := winners_sim_100 + 1

win_rate = setup_count_100 > 0 ? math.round((winners_sim_100 * 100.0) / setup_count_100) : 0

// ============================================================================
// AUTO-DRAW ENTRY/SL/TP LINES
// ============================================================================
var line entry_ln = na
var line sl_ln = na
var line tp1_ln = na
var line tp2_ln = na
var label entry_lbl = na
var label sl_lbl = na
var label tp1_lbl = na
var label tp2_lbl = na

if show_lines and (setup_bull or setup_bear) and barstate.isconfirmed
    // Delete previous
    line.delete(entry_ln)
    line.delete(sl_ln)
    line.delete(tp1_ln)
    line.delete(tp2_ln)
    label.delete(entry_lbl)
    label.delete(sl_lbl)
    label.delete(tp1_lbl)
    label.delete(tp2_lbl)

    // Calculate levels
    float entry_p = close
    float sl_p  = setup_bull ? close - atr14 * sl_atr_mult  : close + atr14 * sl_atr_mult
    float tp1_p = setup_bull ? close + atr14 * tp1_atr_mult : close - atr14 * tp1_atr_mult
    float tp2_p = setup_bull ? close + atr14 * tp2_atr_mult : close - atr14 * tp2_atr_mult

    line_col = setup_bull ? color.new(#00E676, 20) : color.new(#FF1744, 20)

    entry_ln := line.new(bar_index, entry_p, bar_index + 30, entry_p, color = color.new(#FFFFFF, 20), style = line.style_solid, width = 2)
    sl_ln    := line.new(bar_index, sl_p,    bar_index + 30, sl_p,    color = color.new(#FF1744, 30), style = line.style_dashed, width = 2)
    tp1_ln   := line.new(bar_index, tp1_p,   bar_index + 30, tp1_p,   color = color.new(#00E676, 40), style = line.style_dashed, width = 1)
    tp2_ln   := line.new(bar_index, tp2_p,   bar_index + 30, tp2_p,   color = color.new(#00E676, 20), style = line.style_dashed, width = 2)

    entry_lbl := label.new(bar_index + 30, entry_p, "ENTRY " + str.tostring(entry_p, "#.#####"), color = color.new(#FFFFFF, 20), textcolor = color.black, style = label.style_label_left, size = size.small)
    sl_lbl    := label.new(bar_index + 30, sl_p, "SL " + str.tostring(sl_p, "#.#####"),     color = color.new(#FF1744, 30), textcolor = color.white, style = label.style_label_left, size = size.small)
    tp1_lbl   := label.new(bar_index + 30, tp1_p, "TP1 " + str.tostring(tp1_p, "#.#####"), color = color.new(#00E676, 40), textcolor = color.white, style = label.style_label_left, size = size.small)
    tp2_lbl   := label.new(bar_index + 30, tp2_p, "TP2 " + str.tostring(tp2_p, "#.#####"), color = color.new(#00E676, 20), textcolor = color.white, style = label.style_label_left, size = size.small)

// ============================================================================
// POSITION SIZING
// ============================================================================
risk_usd = balance * (risk_pct / 100.0)
sl_dist_l = close - (close - atr14 * sl_atr_mult)
sl_dist_s = (close + atr14 * sl_atr_mult) - close
lots_l = sl_dist_l > 0 ? risk_usd / (sl_dist_l * 100.0) : 0.0
lots_s = sl_dist_s > 0 ? risk_usd / (sl_dist_s * 100.0) : 0.0

// ============================================================================
// KILLZONE BACKGROUND
// ============================================================================
bgcolor(show_kz and in_london and not in_lo_open ? color.new(color.blue, 92) : na,   title = "BG London")
bgcolor(show_kz and in_lo_open                    ? color.new(color.teal, 90) : na, title = "BG London Open")
bgcolor(show_kz and in_ny_am                      ? color.new(color.orange, 92) : na, title = "BG NY AM")
bgcolor(show_kz and in_ny_pm                      ? color.new(color.red, 93) : na,   title = "BG NY PM")
bgcolor(show_kz and in_asia                       ? color.new(color.purple, 94) : na, title = "BG Asia")

// Background per grade
bg_g = grade == "S" ? color.new(#9C27B0, 95) : grade == "A+" ? color.new(#00E676, 95) : grade == "A" ? color.new(#FFC107, 96) : na
bgcolor(bg_g, title = "BG Grade")

// ============================================================================
// DASHBOARD HUD
// ============================================================================
f_dash_pos() =>
    dash_position == "Top Right" ? position.top_right :
     dash_position == "Top Left"  ? position.top_left :
     dash_position == "Bottom Right" ? position.bottom_right :
     position.bottom_left

var table dash = table.new(position.top_right, 2, 26,
                             bgcolor = color.new(#0F172A, 10),
                             border_color = color.new(#FFFFFF, 75),
                             border_width = 1,
                             frame_color = color.new(#DC2626, 30),
                             frame_width = 2)

if show_dash and barstate.islast
    table.clear(dash, 0, 0, 1, 25)

    // Header
    table.cell(dash, 0, 0, "🎯 ICT CYBORG V2", text_color = color.white, text_size = size.small, bgcolor = color.new(#DC2626, 40))
    table.cell(dash, 1, 0, syminfo.ticker,      text_color = color.white, text_size = size.small, bgcolor = color.new(#DC2626, 40))

    // Grade
    table.cell(dash, 0, 1, "🏆 GRADE",     text_color = color.gray, text_size = size.small)
    table.cell(dash, 1, 1, grade,           text_color = color.white, text_size = size.large, bgcolor = grade_col)

    // Confluence
    table.cell(dash, 0, 2, "⚡ Confluence", text_color = color.gray, text_size = size.small)
    table.cell(dash, 1, 2, str.tostring(score) + "/7", text_color = color.white, text_size = size.normal)

    // Probability
    table.cell(dash, 0, 3, "🔬 Probability", text_color = color.gray, text_size = size.small)
    prob_bg = prob >= 70 ? color.new(#00E676, 40) : prob >= 50 ? color.new(#FFC107, 40) : color.new(color.gray, 40)
    table.cell(dash, 1, 3, prob_emoji + " " + str.tostring(prob, "#") + "%", text_color = color.white, text_size = size.small, bgcolor = prob_bg)

    // Expected R
    table.cell(dash, 0, 4, "📊 Expected R", text_color = color.gray, text_size = size.small)
    table.cell(dash, 1, 4, expected_r > 0 ? "+" + str.tostring(expected_r, "#.#") + "R" : "—", text_color = color.white, text_size = size.small)

    // Separator
    table.cell(dash, 0, 5, "━━ BIAS ━━", text_color = color.new(#DC2626, 30), text_size = size.tiny, bgcolor = color.new(#DC2626, 90))
    table.cell(dash, 1, 5, "━━━━━━━━", text_color = color.new(#DC2626, 30), text_size = size.tiny, bgcolor = color.new(#DC2626, 90))

    // Multi-TF
    table.cell(dash, 0, 6, "Multi-TF", text_color = color.gray, text_size = size.small)
    mtf_txt = "W" + f_bias_txt(bias_w) + " D" + f_bias_txt(bias_d) + " H4" + f_bias_txt(bias_h4) + " H1" + f_bias_txt(bias_h1)
    mtf_bg = mtf_aligned ? color.new(#00E676, 40) : color.new(color.gray, 40)
    table.cell(dash, 1, 6, mtf_txt, text_color = color.white, text_size = size.small, bgcolor = mtf_bg)

    // Strength
    table.cell(dash, 0, 7, "Strength", text_color = color.gray, text_size = size.small)
    table.cell(dash, 1, 7, str.tostring(mtf_strength) + "/4", text_color = color.white, text_size = size.small)

    // Regime
    table.cell(dash, 0, 8, "Regime", text_color = color.gray, text_size = size.small)
    table.cell(dash, 1, 8, regime, text_color = color.white, text_size = size.small, bgcolor = regime_col)

    // Separator
    table.cell(dash, 0, 9, "━━ TIME ━━", text_color = color.new(#DC2626, 30), text_size = size.tiny, bgcolor = color.new(#DC2626, 90))
    table.cell(dash, 1, 9, "━━━━━━━━", text_color = color.new(#DC2626, 30), text_size = size.tiny, bgcolor = color.new(#DC2626, 90))

    // Killzone
    table.cell(dash, 0, 10, "Killzone", text_color = color.gray, text_size = size.small)
    kz_bg = in_any_kz ? color.new(#FFC107, 40) : color.new(color.gray, 40)
    table.cell(dash, 1, 10, current_kz, text_color = color.white, text_size = size.small, bgcolor = kz_bg)

    // Next KZ
    table.cell(dash, 0, 11, "Next KZ", text_color = color.gray, text_size = size.small)
    h_left = next_kz_in / 60
    m_left = next_kz_in % 60
    table.cell(dash, 1, 11, next_kz_nm + " in " + str.tostring(h_left) + "h" + str.tostring(m_left) + "m", text_color = color.white, text_size = size.small)

    // Setup
    table.cell(dash, 0, 12, "🎯 Setup", text_color = color.gray, text_size = size.small)
    setup_txt = sb_bull ? "🎯 SB Long" : sb_bear ? "🎯 SB Short" :
                 judas_bull ? "🔄 Judas ↑" : judas_bear ? "🔄 Judas ↓" :
                 po3_bull ? "⚡ PO3 ↑" : po3_bear ? "⚡ PO3 ↓" :
                 bb_bull ? "🧱 BB ↑" : bb_bear ? "🧱 BB ↓" : "—"
    setup_bg = (setup_bull or setup_bear) ? color.new(#FFC107, 40) : color.new(color.gray, 40)
    table.cell(dash, 1, 12, setup_txt, text_color = color.white, text_size = size.small, bgcolor = setup_bg)

    // Separator
    table.cell(dash, 0, 13, "━ ICT ELEMS ━", text_color = color.new(#DC2626, 30), text_size = size.tiny, bgcolor = color.new(#DC2626, 90))
    table.cell(dash, 1, 13, "━━━━━━━━", text_color = color.new(#DC2626, 30), text_size = size.tiny, bgcolor = color.new(#DC2626, 90))

    // FVG
    table.cell(dash, 0, 14, "FVG actifs", text_color = color.gray, text_size = size.small)
    table.cell(dash, 1, 14, "↑" + str.tostring(fvg_bull_cnt) + " ↓" + str.tostring(fvg_bear_cnt), text_color = color.white, text_size = size.small)

    // Sweep
    table.cell(dash, 0, 15, "Sweep", text_color = color.gray, text_size = size.small)
    swp_txt = sweep_h ? "⚠️ High swept" : sweep_l ? "⚠️ Low swept" : "—"
    swp_bg  = (sweep_h or sweep_l) ? color.new(#FF1744, 40) : color.new(color.gray, 40)
    table.cell(dash, 1, 15, swp_txt, text_color = color.white, text_size = size.small, bgcolor = swp_bg)

    // Separator
    table.cell(dash, 0, 16, "━ STATS 100b ━", text_color = color.new(#DC2626, 30), text_size = size.tiny, bgcolor = color.new(#DC2626, 90))
    table.cell(dash, 1, 16, "━━━━━━━━", text_color = color.new(#DC2626, 30), text_size = size.tiny, bgcolor = color.new(#DC2626, 90))

    // Historical stats
    table.cell(dash, 0, 17, "Setups (100b)", text_color = color.gray, text_size = size.small)
    table.cell(dash, 1, 17, str.tostring(setup_count_100), text_color = color.white, text_size = size.small)

    table.cell(dash, 0, 18, "Sim Winrate", text_color = color.gray, text_size = size.small)
    wr_bg = win_rate >= 60 ? color.new(#00E676, 40) : win_rate >= 50 ? color.new(#FFC107, 40) : color.new(color.gray, 40)
    table.cell(dash, 1, 18, str.tostring(win_rate) + "%", text_color = color.white, text_size = size.small, bgcolor = wr_bg)

    // Separator
    table.cell(dash, 0, 19, "━━ RISK ━━", text_color = color.new(#DC2626, 30), text_size = size.tiny, bgcolor = color.new(#DC2626, 90))
    table.cell(dash, 1, 19, "━━━━━━━━", text_color = color.new(#DC2626, 30), text_size = size.tiny, bgcolor = color.new(#DC2626, 90))

    // Balance
    table.cell(dash, 0, 20, "💰 Balance", text_color = color.gray, text_size = size.small)
    table.cell(dash, 1, 20, "$" + str.tostring(balance, "#"), text_color = color.white, text_size = size.small)

    // Risk
    table.cell(dash, 0, 21, "⚠️ Risk", text_color = color.gray, text_size = size.small)
    table.cell(dash, 1, 21, str.tostring(risk_pct) + "% = $" + str.tostring(risk_usd, "#.##"), text_color = color.white, text_size = size.small)

    // Lots suggested
    table.cell(dash, 0, 22, "Lots sug.", text_color = color.gray, text_size = size.small)
    lot_v = setup_bull ? lots_l : setup_bear ? lots_s : 0.0
    table.cell(dash, 1, 22, lot_v == 0.0 ? "—" : str.tostring(lot_v, "#.##"), text_color = color.white, text_size = size.small)

    // Separator
    table.cell(dash, 0, 23, "━━━━━━━━", text_color = color.new(color.gray, 70), text_size = size.tiny)
    table.cell(dash, 1, 23, "━━━━━━━━", text_color = color.new(color.gray, 70), text_size = size.tiny)

    // Footer
    table.cell(dash, 0, 24, "@Davghali", text_color = color.new(color.gray, 30), text_size = size.tiny)
    table.cell(dash, 1, 24, "Cyborg V2.0", text_color = color.new(color.gray, 30), text_size = size.tiny)

// ============================================================================
// VISUAL MARKERS
// ============================================================================
plotshape(sb_bull,    title = "SB Long",   style = shape.labelup,   location = location.belowbar, color = color.new(#00E676, 0), textcolor = color.white, text = "SB", size = size.small)
plotshape(sb_bear,    title = "SB Short",  style = shape.labeldown, location = location.abovebar, color = color.new(#FF1744, 0), textcolor = color.white, text = "SB", size = size.small)
plotshape(judas_bull, title = "J Long",    style = shape.labelup,   location = location.belowbar, color = color.new(#FFC107, 0), textcolor = color.black, text = "J",  size = size.small)
plotshape(judas_bear, title = "J Short",   style = shape.labeldown, location = location.abovebar, color = color.new(#FFC107, 0), textcolor = color.black, text = "J",  size = size.small)
plotshape(po3_bull,   title = "PO3 Long",  style = shape.triangleup,   location = location.belowbar, color = color.new(#9C27B0, 0), size = size.small)
plotshape(po3_bear,   title = "PO3 Short", style = shape.triangledown, location = location.abovebar, color = color.new(#9C27B0, 0), size = size.small)

// ============================================================================
// ALERTS (20 types)
// ============================================================================
// Grade alerts
alert_ok_s    = grade == "S"
alert_ok_aplus= grade == "A+"
alert_ok_a    = grade == "A"
alert_ok_b    = grade == "B"

alertcondition(alert_ok_s,       title = "💎 Grade S",             message = "💎 GRADE S on {{ticker}} | Conf {{plot_0}}/7 | Check NOW")
alertcondition(alert_ok_aplus,   title = "🎯 Grade A+",            message = "🎯 GRADE A+ on {{ticker}} | Confluence strong")
alertcondition(alert_ok_a,       title = "⭐ Grade A",             message = "⭐ GRADE A on {{ticker}}")
alertcondition(alert_ok_b,       title = "✓ Grade B",              message = "✓ Grade B on {{ticker}}")

// Setup alerts
alertcondition(sb_10am_bull,     title = "🎯 SB 10AM NY Long",     message = "🎯 Silver Bullet 10AM NY LONG on {{ticker}}")
alertcondition(sb_10am_bear,     title = "🎯 SB 10AM NY Short",    message = "🎯 Silver Bullet 10AM NY SHORT on {{ticker}}")
alertcondition(sb_3am_bull,      title = "🎯 SB 3AM NY Long",      message = "🎯 Silver Bullet 3AM NY LONG on {{ticker}}")
alertcondition(sb_3am_bear,      title = "🎯 SB 3AM NY Short",     message = "🎯 Silver Bullet 3AM NY SHORT on {{ticker}}")
alertcondition(judas_bull,       title = "🔄 Judas Long",          message = "🔄 Judas Swing LONG on {{ticker}}")
alertcondition(judas_bear,       title = "🔄 Judas Short",         message = "🔄 Judas Swing SHORT on {{ticker}}")
alertcondition(po3_bull,         title = "⚡ PO3 Long",            message = "⚡ Power of Three LONG on {{ticker}}")
alertcondition(po3_bear,         title = "⚡ PO3 Short",           message = "⚡ Power of Three SHORT on {{ticker}}")
alertcondition(bb_bull,          title = "🧱 Breaker Long",        message = "🧱 Breaker Block LONG on {{ticker}}")
alertcondition(bb_bear,          title = "🧱 Breaker Short",       message = "🧱 Breaker Block SHORT on {{ticker}}")

// Market events
alertcondition(mtf_bull,         title = "📈 MTF Bull Aligned",    message = "📈 Multi-TF Aligned BULL on {{ticker}}")
alertcondition(mtf_bear,         title = "📉 MTF Bear Aligned",    message = "📉 Multi-TF Aligned BEAR on {{ticker}}")
alertcondition(sweep_h,          title = "🧹 Sweep High",          message = "🧹 Liquidity Sweep HIGH on {{ticker}}")
alertcondition(sweep_l,          title = "🧹 Sweep Low",           message = "🧹 Liquidity Sweep LOW on {{ticker}}")
alertcondition(regime == "TRENDING", title = "🌊 Trending Regime", message = "🌊 Regime TRENDING on {{ticker}}")
alertcondition(ifvg_bull,        title = "🔁 IFVG Bull",           message = "🔁 IFVG Bull on {{ticker}}")
alertcondition(ifvg_bear,        title = "🔁 IFVG Bear",           message = "🔁 IFVG Bear on {{ticker}}")

