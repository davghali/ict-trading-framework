// @version=6
// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  ICT STRATEGY v1 — CLEAN REBUILD                                         ║
// ║  David Ghali x Claude — 2026-04-21                                       ║
// ║                                                                          ║
// ║  Approach : uses plot() for levels (guaranteed Pine v6 visibility).      ║
// ║  No more label.new spam for right-edge — Pine's native plot labels work. ║
// ║                                                                          ║
// ║  FEATURES :                                                              ║
// ║    • Midnight NY Open (amber line)                                       ║
// ║    • Weekly Open (green line)                                            ║
// ║    • PDH / PDL (indigo)                                                  ║
// ║    • PWH / PWL (cyan)                                                    ║
// ║    • PMH / PML (green)                                                   ║
// ║    • FVG bull/bear (pastel boxes)                                        ║
// ║    • OB bull/bear (pastel boxes)                                         ║
// ║    • BOS / CHoCH detection                                               ║
// ║    • Killzones (optional backgrounds)                                    ║
// ║    • PO3 prev day/week bias                                              ║
// ║    • HUD table (top-right)                                               ║
// ║    • FTMO-ready strategy params                                          ║
// ╚══════════════════════════════════════════════════════════════════════════╝

strategy(
     title                   = "ICT Strategy v1 — PROMPT_ULTIME",
     shorttitle              = "ICT-v1",
     overlay                 = true,
     initial_capital         = 10000,
     default_qty_type        = strategy.percent_of_equity,
     default_qty_value       = 100,
     commission_type         = strategy.commission.percent,
     commission_value        = 0.01,
     slippage                = 2,
     pyramiding              = 0,
     process_orders_on_close = true,
     max_boxes_count         = 500,
     max_lines_count         = 500,
     max_labels_count        = 500,
     max_bars_back           = 500
 )

// ╔══════════════════════════════════════════════════════════════════════════╗
// ║   INPUTS                                                                 ║
// ╚══════════════════════════════════════════════════════════════════════════╝

g_levels  = "📊 Levels"
show_pdh_pdl = input.bool(true,  "PDH / PDL",  group = g_levels)
show_pwh_pwl = input.bool(true,  "PWH / PWL",  group = g_levels)
show_pmh_pml = input.bool(true,  "PMH / PML",  group = g_levels)
show_mid_op  = input.bool(true,  "Midnight Open (00:00 NY)", group = g_levels)
show_wk_op   = input.bool(true,  "Weekly Open", group = g_levels)

g_pd      = "📦 PD Arrays"
show_fvg  = input.bool(true,  "FVG (Fair Value Gap)", group = g_pd)
show_ob   = input.bool(true,  "OB (Order Block)",     group = g_pd)
fvg_ext   = input.int(15,     "Box extension (bars)", minval = 5, maxval = 100, group = g_pd)
fvg_age   = input.int(50,     "Max age (bars)",       minval = 10, maxval = 500, group = g_pd)

g_struct  = "🏗️ Structure"
show_bos  = input.bool(true,  "BOS / CHoCH",          group = g_struct)
swing_len = input.int(10,     "Swing lookback",       minval = 3, maxval = 50, group = g_struct)

g_kz      = "⏰ Killzones"
show_kz   = input.bool(false, "Highlight Killzones (intraday only)", group = g_kz)
kz_tz     = input.string("America/New_York", "Timezone", group = g_kz)
sess_asia   = input.session("2000-0000", "Asia KZ",   group = g_kz)
sess_london = input.session("0200-0500", "London KZ", group = g_kz)
sess_ny_am  = input.session("0930-1100", "NY AM KZ",  group = g_kz)
sess_ny_pm  = input.session("1330-1600", "NY PM KZ",  group = g_kz)

g_hud     = "📟 HUD"
show_hud  = input.bool(true,  "Show HUD table",        group = g_hud)
hud_pos   = input.string("top_right", "HUD position",
     options = ["top_right", "top_left", "bottom_right", "bottom_left", "middle_right"],
     group = g_hud)

// Colors (pastel palette)
C_FVG_BULL    = color.new(#4DB6AC, 92)
C_FVG_BULL_B  = color.new(#4DB6AC, 70)
C_FVG_BEAR    = color.new(#F8BBD0, 92)
C_FVG_BEAR_B  = color.new(#F8BBD0, 70)
C_FVG_MIT     = color.new(#9E9E9E, 95)
C_OB_BULL     = color.new(#81D4FA, 90)
C_OB_BULL_B   = color.new(#81D4FA, 55)
C_OB_BEAR     = color.new(#EF9A9A, 90)
C_OB_BEAR_B   = color.new(#EF9A9A, 55)

// ╔══════════════════════════════════════════════════════════════════════════╗
// ║   DATA : fetch HTF values via request.security (no lookahead)           ║
// ╚══════════════════════════════════════════════════════════════════════════╝

[pdh_val, pdl_val] = request.security(syminfo.tickerid, "D", [high[1], low[1]],
     lookahead = barmerge.lookahead_off)
[pwh_val, pwl_val] = request.security(syminfo.tickerid, "W", [high[1], low[1]],
     lookahead = barmerge.lookahead_off)
[pmh_val, pml_val] = request.security(syminfo.tickerid, "M", [high[1], low[1]],
     lookahead = barmerge.lookahead_off)
d_open_val  = request.security(syminfo.tickerid, "D", open,
     lookahead = barmerge.lookahead_off)
w_open_val  = request.security(syminfo.tickerid, "W", open,
     lookahead = barmerge.lookahead_off)
d_prev_o = request.security(syminfo.tickerid, "D", open[1],  lookahead = barmerge.lookahead_off)
d_prev_c = request.security(syminfo.tickerid, "D", close[1], lookahead = barmerge.lookahead_off)
w_prev_o = request.security(syminfo.tickerid, "W", open[1],  lookahead = barmerge.lookahead_off)
w_prev_c = request.security(syminfo.tickerid, "W", close[1], lookahead = barmerge.lookahead_off)

// ╔══════════════════════════════════════════════════════════════════════════╗
// ║   RELIABLE LEVEL PLOTTING via plot() — 100% Pine v6 guaranteed visible  ║
// ║   plot() auto-creates right-edge price label + legend title              ║
// ╚══════════════════════════════════════════════════════════════════════════╝

plot(show_pdh_pdl ? pdh_val : na, title = "PDH",
     color = color.new(#5C6BC0, 0), linewidth = 1, style = plot.style_linebr)
plot(show_pdh_pdl ? pdl_val : na, title = "PDL",
     color = color.new(#5C6BC0, 0), linewidth = 1, style = plot.style_linebr)

plot(show_pwh_pwl ? pwh_val : na, title = "PWH",
     color = color.new(#26C6DA, 0), linewidth = 1, style = plot.style_linebr)
plot(show_pwh_pwl ? pwl_val : na, title = "PWL",
     color = color.new(#26C6DA, 0), linewidth = 1, style = plot.style_linebr)

plot(show_pmh_pml ? pmh_val : na, title = "PMH",
     color = color.new(#66BB6A, 0), linewidth = 1, style = plot.style_linebr)
plot(show_pmh_pml ? pml_val : na, title = "PML",
     color = color.new(#66BB6A, 0), linewidth = 1, style = plot.style_linebr)

plot(show_mid_op ? d_open_val : na, title = "Midnight",
     color = color.new(#FFAB40, 0), linewidth = 1, style = plot.style_linebr)

plot(show_wk_op ? w_open_val : na, title = "Weekly",
     color = color.new(#66BB6A, 0), linewidth = 2, style = plot.style_linebr)

// ╔══════════════════════════════════════════════════════════════════════════╗
// ║   KILLZONES BACKGROUND (intraday only)                                  ║
// ╚══════════════════════════════════════════════════════════════════════════╝

_is_intra = timeframe.isintraday

_in_asia   = not na(time(timeframe.period, sess_asia,   kz_tz))
_in_london = not na(time(timeframe.period, sess_london, kz_tz))
_in_ny_am  = not na(time(timeframe.period, sess_ny_am,  kz_tz))
_in_ny_pm  = not na(time(timeframe.period, sess_ny_pm,  kz_tz))

bgcolor(show_kz and _is_intra and _in_asia   ? color.new(#9C27B0, 95) : na, title = "Asia KZ BG")
bgcolor(show_kz and _is_intra and _in_london ? color.new(#2196F3, 95) : na, title = "London KZ BG")
bgcolor(show_kz and _is_intra and _in_ny_am  ? color.new(#FF9800, 95) : na, title = "NY AM KZ BG")
bgcolor(show_kz and _is_intra and _in_ny_pm  ? color.new(#E91E63, 95) : na, title = "NY PM KZ BG")

_in_any_kz = _in_asia or _in_london or _in_ny_am or _in_ny_pm
_current_kz = _in_asia ? "Asia" : _in_london ? "London" : _in_ny_am ? "NY AM" : _in_ny_pm ? "NY PM" : "OFF"

// ╔══════════════════════════════════════════════════════════════════════════╗
// ║   POWER OF THREE (PO3) — previous daily / weekly                        ║
// ╚══════════════════════════════════════════════════════════════════════════╝

// Daily PO3 retrospective
_d_range = pdh_val - pdl_val
_d_body  = math.abs(d_prev_c - d_prev_o)
_d_uw    = pdh_val - math.max(d_prev_o, d_prev_c)
_d_lw    = math.min(d_prev_o, d_prev_c) - pdl_val

po3_d_bull = d_prev_c > d_prev_o and _d_lw > _d_uw * 1.5 and _d_body > _d_range * 0.4
po3_d_bear = d_prev_c < d_prev_o and _d_uw > _d_lw * 1.5 and _d_body > _d_range * 0.4
po3_d_dir  = po3_d_bull ? "BULL" : po3_d_bear ? "BEAR" : "NEUT"

// Weekly PO3 retrospective
_w_range = pwh_val - pwl_val
_w_body  = math.abs(w_prev_c - w_prev_o)
_w_uw    = pwh_val - math.max(w_prev_o, w_prev_c)
_w_lw    = math.min(w_prev_o, w_prev_c) - pwl_val

po3_w_bull = w_prev_c > w_prev_o and _w_lw > _w_uw * 1.5 and _w_body > _w_range * 0.4
po3_w_bear = w_prev_c < w_prev_o and _w_uw > _w_lw * 1.5 and _w_body > _w_range * 0.4
po3_w_dir  = po3_w_bull ? "BULL" : po3_w_bear ? "BEAR" : "NEUT"

// Current phase (time-based, NY)
_hr_ny = hour(time, kz_tz)
po3_phase = _hr_ny < 2 ? "ACCUM" : _hr_ny < 5 ? "MANIP" : _hr_ny < 17 ? "DISTRIB" : "CLOSE"

// ╔══════════════════════════════════════════════════════════════════════════╗
// ║   FVG DETECTION                                                          ║
// ╚══════════════════════════════════════════════════════════════════════════╝

type FVG
    float top         = 0.0
    float bottom      = 0.0
    int   created_bar = 0
    string direction  = "bull"
    bool  mitigated   = false
    box   viz         = na

var array<FVG> fvgs = array.new<FVG>()

_fvg_bull = barstate.isconfirmed and low > high[2]
_fvg_bear = barstate.isconfirmed and high < low[2]

if show_fvg and _fvg_bull
    if array.size(fvgs) >= 50
        _old = array.shift(fvgs)
        box.delete(_old.viz)
    _new_fvg = FVG.new(
         top = low, bottom = high[2],
         created_bar = bar_index,
         direction = "bull", mitigated = false,
         viz = box.new(bar_index - 2, low, bar_index + fvg_ext, high[2],
              bgcolor      = C_FVG_BULL,
              border_color = C_FVG_BULL_B,
              border_width = 1))
    array.push(fvgs, _new_fvg)

if show_fvg and _fvg_bear
    if array.size(fvgs) >= 50
        _old = array.shift(fvgs)
        box.delete(_old.viz)
    _new_fvg = FVG.new(
         top = low[2], bottom = high,
         created_bar = bar_index,
         direction = "bear", mitigated = false,
         viz = box.new(bar_index - 2, low[2], bar_index + fvg_ext, high,
              bgcolor      = C_FVG_BEAR,
              border_color = C_FVG_BEAR_B,
              border_width = 1))
    array.push(fvgs, _new_fvg)

// Mitigation + expiry
if array.size(fvgs) > 0 and barstate.isconfirmed
    for i = array.size(fvgs) - 1 to 0
        if i < array.size(fvgs)
            _fvg = array.get(fvgs, i)
            if bar_index - _fvg.created_bar > fvg_age
                box.delete(_fvg.viz)
                array.remove(fvgs, i)
                continue
            if not _fvg.mitigated
                _hit = _fvg.direction == "bull" and low <= _fvg.top or _fvg.direction == "bear" and high >= _fvg.bottom
                if _hit
                    _fvg.mitigated := true
                    box.set_bgcolor(_fvg.viz, C_FVG_MIT)
                    box.set_border_color(_fvg.viz, color.new(#9E9E9E, 80))
                    array.set(fvgs, i, _fvg)

// ╔══════════════════════════════════════════════════════════════════════════╗
// ║   OB DETECTION (simplified : opposite candle before impulsive move)     ║
// ╚══════════════════════════════════════════════════════════════════════════╝

type OB
    float top         = 0.0
    float bottom      = 0.0
    int   created_bar = 0
    string direction  = "bull"
    bool  mitigated   = false
    box   viz         = na

var array<OB> obs = array.new<OB>()

_ob_bull = barstate.isconfirmed and close[1] < open[1] and close > open and close > high[1]
_ob_bear = barstate.isconfirmed and close[1] > open[1] and close < open and close < low[1]

if show_ob and _ob_bull
    if array.size(obs) >= 30
        _old = array.shift(obs)
        box.delete(_old.viz)
    _new_ob = OB.new(
         top = high[1], bottom = low[1],
         created_bar = bar_index - 1,
         direction = "bull", mitigated = false,
         viz = box.new(bar_index - 1, high[1], bar_index + fvg_ext, low[1],
              bgcolor      = C_OB_BULL,
              border_color = C_OB_BULL_B,
              border_width = 1))
    array.push(obs, _new_ob)

if show_ob and _ob_bear
    if array.size(obs) >= 30
        _old = array.shift(obs)
        box.delete(_old.viz)
    _new_ob = OB.new(
         top = high[1], bottom = low[1],
         created_bar = bar_index - 1,
         direction = "bear", mitigated = false,
         viz = box.new(bar_index - 1, high[1], bar_index + fvg_ext, low[1],
              bgcolor      = C_OB_BEAR,
              border_color = C_OB_BEAR_B,
              border_width = 1))
    array.push(obs, _new_ob)

if array.size(obs) > 0 and barstate.isconfirmed
    for i = array.size(obs) - 1 to 0
        if i < array.size(obs)
            _ob = array.get(obs, i)
            if bar_index - _ob.created_bar > fvg_age * 2
                box.delete(_ob.viz)
                array.remove(obs, i)

// ╔══════════════════════════════════════════════════════════════════════════╗
// ║   STRUCTURE : swing points + BOS / CHoCH                                ║
// ╚══════════════════════════════════════════════════════════════════════════╝

_swh = ta.pivothigh(high, swing_len, swing_len)
_swl = ta.pivotlow(low,   swing_len, swing_len)

var float last_sh = na
var float last_sl = na
if not na(_swh)
    last_sh := _swh
if not na(_swl)
    last_sl := _swl

var float broken_sh = na
var float broken_sl = na
var string trend    = "NEUT"

_bos_bull = barstate.isconfirmed and not na(last_sh) and last_sh != broken_sh and close > last_sh
_bos_bear = barstate.isconfirmed and not na(last_sl) and last_sl != broken_sl and close < last_sl

if _bos_bull
    broken_sh := last_sh
    _was_bear = trend == "BEAR"
    trend := "BULL"
    if show_bos
        label.new(bar_index, last_sh, _was_bear ? "CHoCH ↑" : "BOS ↑",
             style     = label.style_label_down,
             color     = _was_bear ? color.new(#FBBF24, 30) : color.new(#10B981, 30),
             textcolor = color.white,
             size      = size.small)

if _bos_bear
    broken_sl := last_sl
    _was_bull = trend == "BULL"
    trend := "BEAR"
    if show_bos
        label.new(bar_index, last_sl, _was_bull ? "CHoCH ↓" : "BOS ↓",
             style     = label.style_label_up,
             color     = _was_bull ? color.new(#FBBF24, 30) : color.new(#EF4444, 30),
             textcolor = color.white,
             size      = size.small)

// ╔══════════════════════════════════════════════════════════════════════════╗
// ║   HUD TABLE (top right — simple, solid bg, guaranteed visible)          ║
// ╚══════════════════════════════════════════════════════════════════════════╝

f_hud_pos(p) =>
    p == "top_right"     ? position.top_right    :
     p == "top_left"      ? position.top_left     :
     p == "bottom_right"  ? position.bottom_right :
     p == "bottom_left"   ? position.bottom_left  :
     position.middle_right

f_dir_col(d) =>
    d == "BULL" ? color.new(#10B981, 0) : d == "BEAR" ? color.new(#EF4444, 0) : color.new(#94A3B8, 0)

var table hud = table.new(
     position     = f_hud_pos(hud_pos),
     columns      = 2,
     rows         = 6,
     bgcolor      = color.new(#0F172A, 5),
     border_color = color.new(#FFD700, 50),
     border_width = 1,
     frame_color  = color.new(#FFD700, 30),
     frame_width  = 2)

if show_hud and barstate.islast
    table.cell(hud, 0, 0, "ICT v1",  text_color = color.white,             text_size = size.small, bgcolor = color.new(#1E293B, 0))
    table.cell(hud, 1, 0, syminfo.ticker, text_color = color.new(#FFD700, 0), text_size = size.small, bgcolor = color.new(#1E293B, 0))
    table.cell(hud, 0, 1, "PO3 D",   text_color = color.new(#94A3B8, 10), text_size = size.tiny)
    table.cell(hud, 1, 1, po3_d_dir, text_color = f_dir_col(po3_d_dir),   text_size = size.tiny)
    table.cell(hud, 0, 2, "PO3 W",   text_color = color.new(#94A3B8, 10), text_size = size.tiny)
    table.cell(hud, 1, 2, po3_w_dir, text_color = f_dir_col(po3_w_dir),   text_size = size.tiny)
    table.cell(hud, 0, 3, "Phase",   text_color = color.new(#94A3B8, 10), text_size = size.tiny)
    table.cell(hud, 1, 3, po3_phase, text_color = color.white,             text_size = size.tiny)
    table.cell(hud, 0, 4, "KZ",      text_color = color.new(#94A3B8, 10), text_size = size.tiny)
    table.cell(hud, 1, 4, _current_kz, text_color = _in_any_kz ? color.new(#10B981, 0) : color.new(#94A3B8, 0), text_size = size.tiny)
    table.cell(hud, 0, 5, "Trend",   text_color = color.new(#94A3B8, 10), text_size = size.tiny)
    table.cell(hud, 1, 5, trend,     text_color = f_dir_col(trend),       text_size = size.tiny)

// ╔══════════════════════════════════════════════════════════════════════════╗
// ║   END OF ICT Strategy v1 (clean rebuild)                                ║
// ╚══════════════════════════════════════════════════════════════════════════╝
