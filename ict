#!/usr/bin/env python3
"""
ict — CLI unifié du framework.

Commandes :
  ict setup              — installation complète (deps + data + ML)
  ict dashboard          — site local (localhost + LAN, accessible phone Wi-Fi)
  ict serve-public       — site PUBLIC via Cloudflare Tunnel (URL internet)
  ict serve-ngrok        — site PUBLIC via ngrok (alternative)
  ict scan               — scan one-shot CLI
  ict daemon             — daemon live (scanner + alertes 24/7)
  ict test               — test alertes Discord/Telegram
  ict backtest <asset>   — backtest rapide
  ict status             — health check
  ict calendar           — affiche news à venir
  ict install-autostart  — installe LaunchAgents (dashboard + tunnel + daemon)
  ict uninstall-autostart— retire tous les LaunchAgents
  ict services           — status des services autostart
  ict url                — affiche URL publique actuelle (+copie clipboard)
"""
import sys
import os
import subprocess
from pathlib import Path


ROOT = Path(__file__).resolve().parent


def cmd_setup():
    """Installe tout ce qu'il faut."""
    print("═══ SETUP — Installation complète ═══")
    # 1. pip install
    print("\n[1/4] Install Python dependencies...")
    subprocess.run([sys.executable, "-m", "pip", "install", "--quiet",
                    "-r", str(ROOT / "requirements.txt")], check=False)
    subprocess.run([sys.executable, "-m", "pip", "install", "--quiet",
                    "streamlit"], check=False)
    print("   ✓ Python deps installed")

    # 2. Download data
    print("\n[2/4] Download market data (Yahoo Finance)...")
    subprocess.run([sys.executable, "-c", """
import sys; sys.path.insert(0, '.')
import warnings; warnings.filterwarnings('ignore')
from src.data_engine import download_asset
from src.utils.types import Timeframe
from src.utils.config import list_instruments
symbols = list_instruments()
for sym in symbols:
    for tf in [Timeframe.D1, Timeframe.H1]:
        try:
            df = download_asset(sym, tf, save=True)
        except Exception as e:
            print(f'  skip {sym} {tf.value}: {e}')
"""], cwd=ROOT, check=False)
    print("   ✓ Data ready")

    # 3. Initialize user settings
    print("\n[3/4] Initialize user settings...")
    subprocess.run([sys.executable, "-c", """
import sys; sys.path.insert(0, '.')
from src.utils.user_settings import UserSettings
s = UserSettings.load()
s.save()
print('   ✓ settings saved to user_data/')
"""], cwd=ROOT, check=False)

    # 4. Run verification
    print("\n[4/4] Verification finale...")
    subprocess.run([sys.executable, "run_verify.py"], cwd=ROOT, check=False)
    print("\n═══ SETUP TERMINÉ ═══")
    print("\nLance maintenant :")
    print("  ./ict dashboard    — interface visuelle")
    print("  ./ict daemon       — scan continu + alertes")


def cmd_dashboard():
    """Lance Streamlit dashboard (accessible localhost + LAN)."""
    ip = _get_lan_ip()
    print("╔════════════════════════════════════════════════════════════╗")
    print("║  🔴 ICT Framework — Dashboard accessible sur :             ║")
    print(f"║    💻 Mac        : http://localhost:8501                   ║")
    if ip:
        print(f"║    📱 Phone/LAN  : http://{ip}:8501  {(' '*(25-len(ip)))}║")
    print("║  Ctrl+C pour arrêter                                       ║")
    print("╚════════════════════════════════════════════════════════════╝")
    subprocess.run([
        sys.executable, "-m", "streamlit", "run", str(ROOT / "dashboard.py"),
        "--server.address=0.0.0.0",
        "--server.port=8501",
        "--browser.gatherUsageStats=false",
    ], cwd=ROOT)


def cmd_serve_public():
    """Lance dashboard + tunnel Cloudflare → URL publique permanente gratuite."""
    import shutil
    # Try local bundled cloudflared first, then PATH
    local_cf = ROOT / "bin" / "cloudflared"
    cloudflared_bin = str(local_cf) if local_cf.exists() else shutil.which("cloudflared")
    if not cloudflared_bin:
        print("❌ cloudflared pas installé.")
        print("   Téléchargement auto... ou installe via :")
        print("   brew install cloudflared")
        return

    ip = _get_lan_ip()
    print("╔════════════════════════════════════════════════════════════╗")
    print("║  🌍 Lancement dashboard + tunnel Cloudflare (URL publique) ║")
    print("╚════════════════════════════════════════════════════════════╝")

    # Start Streamlit in background
    import time
    streamlit = subprocess.Popen([
        sys.executable, "-m", "streamlit", "run", str(ROOT / "dashboard.py"),
        "--server.address=0.0.0.0", "--server.port=8501",
        "--browser.gatherUsageStats=false", "--server.headless=true",
    ], cwd=ROOT)
    time.sleep(4)
    print(f"  💻 Local     : http://localhost:8501")
    if ip:
        print(f"  📱 LAN       : http://{ip}:8501")
    print(f"  🌍 Public    : (URL apparaît ci-dessous dans 10s)\n")

    try:
        # Start tunnel (blocking, prints URL)
        subprocess.run([cloudflared_bin, "tunnel", "--url", "http://localhost:8501"])
    except KeyboardInterrupt:
        pass
    finally:
        streamlit.terminate()
        print("\n✓ Tunnel + dashboard arrêtés.")


def cmd_serve_ngrok():
    """Alternative avec ngrok (plus simple mais URL change à chaque fois)."""
    import shutil
    if not shutil.which("ngrok"):
        print("❌ ngrok pas installé.")
        print("   brew install ngrok       # macOS")
        print("   Puis : ngrok config add-authtoken <TOKEN>")
        print("   Token : https://dashboard.ngrok.com/get-started/your-authtoken")
        return

    import time
    streamlit = subprocess.Popen([
        sys.executable, "-m", "streamlit", "run", str(ROOT / "dashboard.py"),
        "--server.address=0.0.0.0", "--server.port=8501",
        "--browser.gatherUsageStats=false", "--server.headless=true",
    ], cwd=ROOT)
    time.sleep(4)
    print(f"  💻 Local : http://localhost:8501")
    print(f"  🌍 Public: (URL ngrok apparaît ci-dessous)\n")
    try:
        subprocess.run(["ngrok", "http", "8501"])
    except KeyboardInterrupt:
        pass
    finally:
        streamlit.terminate()


def _get_lan_ip():
    try:
        import socket
        s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
        s.connect(("8.8.8.8", 80))
        ip = s.getsockname()[0]
        s.close()
        return ip
    except Exception:
        return None


