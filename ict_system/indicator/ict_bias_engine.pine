// @version=6
// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  ICT BIAS CLEAN — biais par UT, rien d'autre                            ║
// ║  David Ghali x Claude                                                    ║
// ║                                                                          ║
// ║  RÈGLE ICT OFFICIELLE (Michael J. Huddleston) :                          ║
// ║    • Price > TF Open  →  BULL                                            ║
// ║    • Price < TF Open  →  BEAR                                            ║
// ║                                                                          ║
// ║  Aucun plot, aucune ligne, aucun swing, aucun PO3.                       ║
// ║  Juste un HUD compact en haut-droite avec le biais W/D/H4/H1/M15.        ║
// ╚══════════════════════════════════════════════════════════════════════════╝

indicator(
     title      = "ICT Bias Clean",
     shorttitle = "ICT BIAS",
     overlay    = true)

// ── Inputs (minimalistes) ────────────────────────────────────────────────
pos_in = input.string("top_right", "HUD Position",
     options = ["top_right", "top_left", "bottom_right", "bottom_left", "middle_right"])

col_bull = input.color(color.new(#10B981, 0), "BULL color")
col_bear = input.color(color.new(#EF4444, 0), "BEAR color")
col_neut = input.color(color.new(#94A3B8, 0), "NEUT color")

// ── Fetch Opens per TF (request.security, no lookahead) ─────────────────
w_open   = request.security(syminfo.tickerid, "W",   open, lookahead = barmerge.lookahead_off)
d_open   = request.security(syminfo.tickerid, "D",   open, lookahead = barmerge.lookahead_off)
h4_open  = request.security(syminfo.tickerid, "240", open, lookahead = barmerge.lookahead_off)
h1_open  = request.security(syminfo.tickerid, "60",  open, lookahead = barmerge.lookahead_off)
m15_open = request.security(syminfo.tickerid, "15",  open, lookahead = barmerge.lookahead_off)

// ── OFFICIAL ICT BIAS RULE : price vs TF Open ────────────────────────────
f_bias(float p, float o) =>
    p > o ? "BULL" : p < o ? "BEAR" : "NEUT"

f_col(string b) =>
    b == "BULL" ? col_bull : b == "BEAR" ? col_bear : col_neut

bias_w   = f_bias(close, w_open)
bias_d   = f_bias(close, d_open)
bias_h4  = f_bias(close, h4_open)
bias_h1  = f_bias(close, h1_open)
bias_m15 = f_bias(close, m15_open)

// ── HUD position helper ────────────────────────────────────────────────
f_pos(string p) =>
    p == "top_right"    ? position.top_right    :
     p == "top_left"     ? position.top_left     :
     p == "bottom_right" ? position.bottom_right :
     p == "bottom_left"  ? position.bottom_left  :
     position.middle_right

// ── HUD TABLE (minimaliste) ────────────────────────────────────────────
var table t = table.new(
     position     = f_pos(pos_in),
     columns      = 2,
     rows         = 6,
     bgcolor      = color.new(#0F172A, 0),
     border_color = color.new(#FFD700, 40),
     border_width = 1,
     frame_color  = color.new(#FFD700, 20),
     frame_width  = 2)

if barstate.islast
    // Header
    table.cell(t, 0, 0, "TF",   text_color = color.white, text_size = size.normal, bgcolor = color.new(#1E293B, 0))
    table.cell(t, 1, 0, "BIAS", text_color = color.white, text_size = size.normal, bgcolor = color.new(#1E293B, 0))

    // Rows
    table.cell(t, 0, 1, "W",    text_color = color.new(#94A3B8, 10), text_size = size.normal)
    table.cell(t, 1, 1, bias_w, text_color = f_col(bias_w),          text_size = size.normal)

    table.cell(t, 0, 2, "D",    text_color = color.new(#94A3B8, 10), text_size = size.normal)
    table.cell(t, 1, 2, bias_d, text_color = f_col(bias_d),          text_size = size.normal)

    table.cell(t, 0, 3, "H4",   text_color = color.new(#94A3B8, 10), text_size = size.normal)
    table.cell(t, 1, 3, bias_h4, text_color = f_col(bias_h4),        text_size = size.normal)

    table.cell(t, 0, 4, "H1",   text_color = color.new(#94A3B8, 10), text_size = size.normal)
    table.cell(t, 1, 4, bias_h1, text_color = f_col(bias_h1),        text_size = size.normal)

    table.cell(t, 0, 5, "M15",  text_color = color.new(#94A3B8, 10), text_size = size.normal)
    table.cell(t, 1, 5, bias_m15, text_color = f_col(bias_m15),      text_size = size.normal)

// End ───────────────────────────────────────────────────────────────────
