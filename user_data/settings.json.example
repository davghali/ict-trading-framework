{
  "_comment": "Copier vers settings.json et adapter. NE PAS commit settings.json (contient config perso).",
  "firm": "ftmo",
  "variant": "classic_challenge",
  "account_balance": 100000.0,
  "risk_per_trade_pct": 0.5,
  "daily_soft_cap_pct": 2.5,
  "daily_hard_cap_pct": 3.5,
  "assets_h1": ["XAUUSD", "XAGUSD", "BTCUSD", "ETHUSD", "NAS100", "SPX500", "DOW30", "GER40", "UK100"],
  "assets_d1": ["EURUSD", "GBPUSD", "USDJPY", "AUDUSD", "USDCAD", "NZDUSD", "USDCHF", "EURJPY", "GBPJPY", "EURGBP"],
  "scan_interval_minutes": 15,
  "default_tier": "balanced",
  "min_alert_tier": "BALANCED",
  "desktop_notifications": true,
  "sound_alerts": true,
  "skip_news_minutes_before": 30,
  "skip_news_minutes_after": 30,
  "skip_news_impact": "high",
  "use_partial_tp": true,
  "partial_tp_at_r": 1.0,
  "partial_tp_pct": 0.5,
  "move_be_at_r": 0.5,

  "_phase1_comment": "Phase 1 — multi-partial exits + runner trailing",
  "use_multi_partial_exits": true,
  "partial_exit_levels": [
    {"at_r": 1.0, "close_pct": 0.25, "move_sl_to": "entry"},
    {"at_r": 2.0, "close_pct": 0.25, "move_sl_to": "entry_plus_0.5R"},
    {"at_r": 3.0, "close_pct": 0.25, "move_sl_to": "entry_plus_1.5R"}
  ],
  "runner_trailing_atr_mult": 2.0,
  "runner_target_min_r": 5.0,

  "_phase2_comment": "Phase 2 — confluence + dynamic risk + news ride",
  "use_confluence_filter": true,
  "confluence_min_score": 3,
  "confluence_require_smt": true,
  "confluence_require_multi_tf": true,
  "use_dynamic_risk": true,
  "dynamic_risk_base": 0.5,
  "dynamic_risk_max": 1.0,
  "dynamic_risk_min": 0.25,
  "dynamic_risk_hot_streak_boost": 0.2,
  "dynamic_risk_cold_streak_penalty": 0.25,
  "use_news_ride": false,
  "news_ride_wait_minutes": 5,
  "news_ride_retracement_pct": 0.618,
  "news_ride_risk_multiplier": 0.5,

  "_phase3_comment": "Phase 3 — pyramid + ML regime-aware",
  "use_pyramid": true,
  "pyramid_max_adds": 2,
  "pyramid_add_at_r": 1.0,
  "pyramid_add_risk_pct": 0.3,
  "ml_retrain_frequency": "daily",
  "ml_use_regime_detection": true,
  "min_grade_sniper": "A+",

  "_auto_execution_comment": "Full-auto MT5 execution (passez auto_execute a false pour signal-only)",
  "auto_execute": true,
  "auto_max_concurrent_positions": 5,
  "auto_max_positions_per_symbol": 1,
  "auto_daily_loss_cap_pct": 3.5,
  "auto_min_balance_pct": 90.0,
  "auto_allow_weekends": false,
  "auto_trading_days_utc": [0, 1, 2, 3, 4],
  "auto_friday_cutoff_hour_utc": 15,
  "auto_monday_earliest_hour_utc": 7,
  "position_check_interval": 60
}
