def cmd_install_autostart():
    """Installe LaunchAgent macOS."""
    if sys.platform != "darwin":
        print("Autostart only supported on macOS currently.")
        return
    plist_dir = Path.home() / "Library" / "LaunchAgents"
    plist_dir.mkdir(exist_ok=True)
    plist_path = plist_dir / "com.ictframework.daemon.plist"
    plist = f"""<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key><string>com.ictframework.daemon</string>
  <key>ProgramArguments</key>
  <array>
    <string>{sys.executable}</string>
    <string>{ROOT}/run_daemon.py</string>
    <string>--interval</string><string>15</string>
    <string>--tier</string><string>balanced</string>
  </array>
  <key>RunAtLoad</key><true/>
  <key>KeepAlive</key><true/>
  <key>WorkingDirectory</key><string>{ROOT}</string>
  <key>StandardOutPath</key><string>{ROOT}/reports/logs/daemon.log</string>
  <key>StandardErrorPath</key><string>{ROOT}/reports/logs/daemon.err</string>
</dict>
</plist>
"""
    plist_path.write_text(plist)
    subprocess.run(["launchctl", "unload", str(plist_path)], check=False,
                    capture_output=True)
    subprocess.run(["launchctl", "load", str(plist_path)], check=True)
    print(f"✓ LaunchAgent installé : {plist_path}")
    print("  Le daemon démarrera automatiquement au login.")
    print("  Logs : reports/logs/daemon.log")


def cmd_uninstall_autostart():
    if sys.platform != "darwin":
        return
    plist_path = Path.home() / "Library" / "LaunchAgents" / "com.ictframework.daemon.plist"
    if plist_path.exists():
        subprocess.run(["launchctl", "unload", str(plist_path)], check=False,
                        capture_output=True)
        plist_path.unlink()
        print(f"✓ LaunchAgent retiré : {plist_path}")
    else:
        print("Pas de LaunchAgent installé.")


USAGE = __doc__


def main():
    if len(sys.argv) < 2:
        print(USAGE)
        sys.exit(0)

    cmd = sys.argv[1]
    args = sys.argv[2:]

    routes = {
        "setup": lambda: cmd_setup(),
        "dashboard": lambda: cmd_dashboard(),
        "serve-public": lambda: cmd_serve_public(),
        "serve-ngrok": lambda: cmd_serve_ngrok(),
        "scan": lambda: cmd_scan(),
        "daemon": lambda: cmd_daemon(args),
        "test": lambda: cmd_test_alerts(),
        "backtest": lambda: cmd_backtest(args),
        "status": lambda: cmd_status(),
        "calendar": lambda: cmd_calendar(),
        "install-autostart": lambda: cmd_install_autostart(),
        "uninstall-autostart": lambda: cmd_uninstall_autostart(),
        "help": lambda: print(USAGE),
        "--help": lambda: print(USAGE),
        "-h": lambda: print(USAGE),
    }
    if cmd not in routes:
        print(f"Unknown command: {cmd}\n")
        print(USAGE)
        sys.exit(1)
    routes[cmd]()


if __name__ == "__main__":
    main()
