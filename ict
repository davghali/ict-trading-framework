def cmd_install_autostart():
    """Installe LaunchAgents macOS : dashboard + tunnel + daemon (auto-start)."""
    if sys.platform != "darwin":
        print("Autostart only supported on macOS currently.")
        return
    subprocess.run(["bash", str(ROOT / "scripts" / "install_autostart.sh")], check=True)


def cmd_uninstall_autostart():
    if sys.platform != "darwin":
        return
    subprocess.run(["bash", str(ROOT / "scripts" / "uninstall_autostart.sh")], check=True)


def cmd_url():
    """Affiche l'URL publique actuelle + la copie dans le clipboard."""
    url_file = ROOT / "user_data" / "public_url.txt"
    if not url_file.exists():
        print("❌ Pas d'URL publique enregistrée.")
        print("   Lance l'autostart : ./ict install-autostart")
        print("   Ou manuel : ./ict serve-public")
        return
    url = url_file.read_text().strip()
    if not url:
        print("❌ URL vide (tunnel pas encore actif ?)")
        return
    print("╔═══════════════════════════════════════════════════════════════════╗")
    print("║  🌍 TON URL PUBLIQUE                                             ║")
    print("╚═══════════════════════════════════════════════════════════════════╝")
    print()
    print(f"   {url}")
    print()
    # Copy to clipboard
    try:
        subprocess.run(["pbcopy"], input=url.encode(), check=True)
        print("   ✓ Copiée dans le clipboard (Cmd+V pour coller)")
    except Exception:
        pass
    # Also LAN
    ip = _get_lan_ip()
    if ip:
        print()
        print(f"   📱 LAN (phone Wi-Fi) : http://{ip}:8501")
    print(f"   💻 Local             : http://localhost:8501")
    print()


def cmd_status_services():
    """Check si les services autostart tournent."""
    if sys.platform != "darwin":
        print("macOS only.")
        return
    result = subprocess.run(["launchctl", "list"], capture_output=True, text=True)
    running = [l for l in result.stdout.splitlines() if "ictframework" in l]
    print("╔═══════════════════════════════════════════════════════════════════╗")
    print("║  📊 SERVICES STATUS                                              ║")
    print("╚═══════════════════════════════════════════════════════════════════╝")
    if not running:
        print("  ❌ Aucun service actif. Lance : ./ict install-autostart")
        return
    for line in running:
        cols = line.split()
        pid = cols[0] if cols else "?"
        status = cols[1] if len(cols) > 1 else "?"
        label = cols[2] if len(cols) > 2 else "?"
        icon = "✅" if pid != "-" else "⚠"
        print(f"  {icon} {label:40s} PID={pid} status={status}")

    # Dashboard reachable?
    print()
    import urllib.request
    try:
        urllib.request.urlopen("http://localhost:8501/_stcore/health", timeout=3)
        print("  ✅ Dashboard répond sur http://localhost:8501")
    except Exception:
        print("  ⚠ Dashboard NE répond PAS (démarrage en cours ?)")
    # URL file
    url_file = ROOT / "user_data" / "public_url.txt"
    if url_file.exists() and url_file.read_text().strip():
        print(f"  🌍 URL publique   : {url_file.read_text().strip()}")


USAGE = __doc__


def main():
    if len(sys.argv) < 2:
        print(USAGE)
        sys.exit(0)

    cmd = sys.argv[1]
    args = sys.argv[2:]

    routes = {
        "setup": lambda: cmd_setup(),
        "dashboard": lambda: cmd_dashboard(),
        "serve-public": lambda: cmd_serve_public(),
        "serve-ngrok": lambda: cmd_serve_ngrok(),
        "scan": lambda: cmd_scan(),
        "daemon": lambda: cmd_daemon(args),
        "test": lambda: cmd_test_alerts(),
        "backtest": lambda: cmd_backtest(args),
        "status": lambda: cmd_status(),
        "services": lambda: cmd_status_services(),
        "url": lambda: cmd_url(),
        "calendar": lambda: cmd_calendar(),
        "install-autostart": lambda: cmd_install_autostart(),
        "uninstall-autostart": lambda: cmd_uninstall_autostart(),
        "help": lambda: print(USAGE),
        "--help": lambda: print(USAGE),
        "-h": lambda: print(USAGE),
    }
    if cmd not in routes:
        print(f"Unknown command: {cmd}\n")
        print(USAGE)
        sys.exit(1)
    routes[cmd]()


if __name__ == "__main__":
    main()
