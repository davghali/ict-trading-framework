// @version=6
// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  ICT BIAS v3 CERTAINTY — Multi-factor confidence engine                  ║
// ║  David Ghali x Claude                                                    ║
// ║                                                                          ║
// ║  POUR CHAQUE UT (W / D / H4 / H1 / M15) :                                ║
// ║                                                                          ║
// ║    • BIAIS CONFIRMÉ  : close de la bougie précédente vs son open         ║
// ║    • BIAIS LIVE      : prix actuel vs open de la bougie en cours         ║
// ║    • CONFIANCE %     : score composite 0-100 basé sur 4 facteurs :       ║
// ║        1. Time-in-candle     (plus la bougie avance, plus c'est sûr)     ║
// ║        2. Distance from open (corps dominant = biais engagé)             ║
// ║        3. HTF alignment      (biais matche TF supérieure = bonus)        ║
// ║        4. Historical hit rate (sur 50 bougies, % qui ont tenu le biais)  ║
// ║                                                                          ║
// ║  ⭐ = Confirmed + Live alignés → haute certitude                          ║
// ║  ⚠️ = Divergence → prudence                                              ║
// ║                                                                          ║
// ║  Rien d'autre sur le chart. Juste un HUD compact.                        ║
// ╚══════════════════════════════════════════════════════════════════════════╝

indicator(
     title       = "ICT Bias v3 Certainty",
     shorttitle  = "ICT BIAS v3",
     overlay     = true)

// ── INPUTS ────────────────────────────────────────────────────────────
pos_in        = input.string("top_right", "HUD position",
     options = ["top_right", "top_left", "bottom_right", "bottom_left", "middle_right"])
hist_lookback = input.int(50, "Historical lookback (bars)",
     minval = 10, maxval = 200,
     tooltip = "Nombre de bougies passées pour calculer le hit rate historique par UT")
dist_cap_pct  = input.float(1.0, "Distance cap % (pour scoring)",
     minval = 0.1, maxval = 5.0, step = 0.1,
     tooltip = "Distance prix/open au-delà de laquelle le score distance est max. Ex: 1% sur forex, 2-3% sur crypto")

col_bull = input.color(color.new(#10B981, 0), "BULL")
col_bear = input.color(color.new(#EF4444, 0), "BEAR")
col_neut = input.color(color.new(#94A3B8, 0), "NEUT")
col_warn = input.color(color.new(#FBBF24, 0), "Alignment warning")

// ── HELPER : HUD position ────────────────────────────────────────────
f_pos(string p) =>
    p == "top_right"    ? position.top_right    :
     p == "top_left"     ? position.top_left     :
     p == "bottom_right" ? position.bottom_right :
     p == "bottom_left"  ? position.bottom_left  :
     position.middle_right

// ── HELPER : bias from open ─────────────────────────────────────────
f_bias(float price, float o) =>
    price > o ? "BULL" : price < o ? "BEAR" : "NEUT"

f_col(string b) =>
    b == "BULL" ? col_bull : b == "BEAR" ? col_bear : col_neut

// ── FETCH per-TF data ───────────────────────────────────────────────
// For each TF, we fetch :
//   - current candle : o, h, l, c
//   - previous candle : pc (prev close), po (prev open)
//   - open_time, close_time (for elapsed %)
//   - historical bull rate (% of last N bars that closed bull)

f_tf_data(simple string tf, simple int lookback) =>
    _o  = request.security(syminfo.tickerid, tf, open,       lookahead = barmerge.lookahead_off)
    _h  = request.security(syminfo.tickerid, tf, high,       lookahead = barmerge.lookahead_off)
    _l  = request.security(syminfo.tickerid, tf, low,        lookahead = barmerge.lookahead_off)
    _c  = request.security(syminfo.tickerid, tf, close,      lookahead = barmerge.lookahead_off)
    _pc = request.security(syminfo.tickerid, tf, close[1],   lookahead = barmerge.lookahead_off)
    _po = request.security(syminfo.tickerid, tf, open[1],    lookahead = barmerge.lookahead_off)
    _ot = request.security(syminfo.tickerid, tf, time,       lookahead = barmerge.lookahead_off)
    _ct = request.security(syminfo.tickerid, tf, time_close, lookahead = barmerge.lookahead_off)
    // Historical hit rate : bull candles / total in lookback, expressed as %
    _bull_rate = request.security(syminfo.tickerid, tf,
         math.sum(close > open ? 1 : 0, lookback) / lookback * 100,
         lookahead = barmerge.lookahead_off)
    [_o, _h, _l, _c, _pc, _po, _ot, _ct, _bull_rate]

[w_o,   w_h,   w_l,   w_c,   w_pc,   w_po,   w_ot,   w_ct,   w_bullrate]   = f_tf_data("W",   hist_lookback)
[d_o,   d_h,   d_l,   d_c,   d_pc,   d_po,   d_ot,   d_ct,   d_bullrate]   = f_tf_data("D",   hist_lookback)
[h4_o,  h4_h,  h4_l,  h4_c,  h4_pc,  h4_po,  h4_ot,  h4_ct,  h4_bullrate]  = f_tf_data("240", hist_lookback)
[h1_o,  h1_h,  h1_l,  h1_c,  h1_pc,  h1_po,  h1_ot,  h1_ct,  h1_bullrate]  = f_tf_data("60",  hist_lookback)
[m15_o, m15_h, m15_l, m15_c, m15_pc, m15_po, m15_ot, m15_ct, m15_bullrate] = f_tf_data("15",  hist_lookback)

cur_price = close

// ── BIAIS : CONFIRMED + LIVE ─────────────────────────────────────────
// Confirmed = direction of PREVIOUS closed candle (pc > po)
// Live      = current price vs current open

conf_bias_w   = f_bias(w_pc,   w_po)
live_bias_w   = f_bias(cur_price, w_o)

conf_bias_d   = f_bias(d_pc,   d_po)
live_bias_d   = f_bias(cur_price, d_o)

conf_bias_h4  = f_bias(h4_pc,  h4_po)
live_bias_h4  = f_bias(cur_price, h4_o)

conf_bias_h1  = f_bias(h1_pc,  h1_po)
live_bias_h1  = f_bias(cur_price, h1_o)

conf_bias_m15 = f_bias(m15_pc, m15_po)
live_bias_m15 = f_bias(cur_price, m15_o)

// ── CONFIDENCE SCORE (4 factors, each 25 points max = 100 total) ────

// FACTOR 1 : Time-in-candle % (how far we are through the candle)
f_elapsed_pct(int ot, int ct) =>
    _dur = ct - ot
    _dur > 0 ? math.min(100.0, math.max(0.0, (timenow - ot) / _dur * 100.0)) : 0.0

elapsed_w   = f_elapsed_pct(w_ot,   w_ct)
elapsed_d   = f_elapsed_pct(d_ot,   d_ct)
elapsed_h4  = f_elapsed_pct(h4_ot,  h4_ct)
elapsed_h1  = f_elapsed_pct(h1_ot,  h1_ct)
elapsed_m15 = f_elapsed_pct(m15_ot, m15_ct)

// FACTOR 2 : Distance from open (% of price)
f_dist_pct(float p, float o) =>
    o != 0 ? math.abs((p - o) / o * 100) : 0.0

dist_w   = f_dist_pct(cur_price, w_o)
dist_d   = f_dist_pct(cur_price, d_o)
dist_h4  = f_dist_pct(cur_price, h4_o)
dist_h1  = f_dist_pct(cur_price, h1_o)
dist_m15 = f_dist_pct(cur_price, m15_o)

// FACTOR 3 : HTF alignment (live bias matches higher TF live bias)
// W : no HTF → auto 100% for factor 3
// D : align with W
// H4 : align with D
// H1 : align with H4
// M15 : align with H1

htf_align_w   = true  // no higher TF
htf_align_d   = live_bias_d   == live_bias_w
htf_align_h4  = live_bias_h4  == live_bias_d
htf_align_h1  = live_bias_h1  == live_bias_h4
htf_align_m15 = live_bias_m15 == live_bias_h1

// FACTOR 4 : Historical hit rate alignment
// If live bias is BULL : hist_bull_rate should be > 50 for confidence
// If live bias is BEAR : hist_bull_rate should be < 50 for confidence
// Score = alignment with historical tendency
f_hist_score(string live, float bull_rate) =>
    live == "BULL" ? bull_rate : live == "BEAR" ? 100 - bull_rate : 50

hist_w   = f_hist_score(live_bias_w,   w_bullrate)
hist_d   = f_hist_score(live_bias_d,   d_bullrate)
hist_h4  = f_hist_score(live_bias_h4,  h4_bullrate)
hist_h1  = f_hist_score(live_bias_h1,  h1_bullrate)
hist_m15 = f_hist_score(live_bias_m15, m15_bullrate)

// ── COMPUTE CONFIDENCE per TF (0-100) ───────────────────────────────
// Time : 25% weight
// Distance : 25% weight (capped at dist_cap_pct)
// HTF alignment : 25% weight (binary)
// Historical : 25% weight (scaled)
// Bonus +10% if CONFIRMED and LIVE agree (=> alignment ⭐)

f_confidence(float elapsed, float dist, bool htf_al, float hist, bool confirm_live_match,
             simple float cap) =>
    _f1 = elapsed * 0.25                              // 0 → 25
    _f2 = math.min(dist / cap, 1.0) * 25              // 0 → 25
    _f3 = htf_al ? 25.0 : 0.0                         // 0 or 25
    _f4 = hist * 0.25                                 // 0 → 25
    _bonus = confirm_live_match ? 0.0 : -10.0         // penalty if divergent
    math.max(0.0, math.min(100.0, _f1 + _f2 + _f3 + _f4 + _bonus))

conf_w   = f_confidence(elapsed_w,   dist_w,   htf_align_w,   hist_w,   conf_bias_w   == live_bias_w,   dist_cap_pct)
conf_d   = f_confidence(elapsed_d,   dist_d,   htf_align_d,   hist_d,   conf_bias_d   == live_bias_d,   dist_cap_pct)
conf_h4  = f_confidence(elapsed_h4,  dist_h4,  htf_align_h4,  hist_h4,  conf_bias_h4  == live_bias_h4,  dist_cap_pct)
conf_h1  = f_confidence(elapsed_h1,  dist_h1,  htf_align_h1,  hist_h1,  conf_bias_h1  == live_bias_h1,  dist_cap_pct)
conf_m15 = f_confidence(elapsed_m15, dist_m15, htf_align_m15, hist_m15, conf_bias_m15 == live_bias_m15, dist_cap_pct)

// ── ALIGNMENT STAR (Confirmed + Live match) ─────────────────────────
star_w   = conf_bias_w   == live_bias_w   ? "⭐" : "⚠️"
star_d   = conf_bias_d   == live_bias_d   ? "⭐" : "⚠️"
star_h4  = conf_bias_h4  == live_bias_h4  ? "⭐" : "⚠️"
star_h1  = conf_bias_h1  == live_bias_h1  ? "⭐" : "⚠️"
star_m15 = conf_bias_m15 == live_bias_m15 ? "⭐" : "⚠️"

// ── HUD TABLE ────────────────────────────────────────────────────────
var table t = table.new(
     position     = f_pos(pos_in),
     columns      = 5,
     rows         = 8,
     bgcolor      = color.new(#0F172A, 0),
     border_color = color.new(#FFD700, 40),
     border_width = 1,
     frame_color  = color.new(#FFD700, 20),
     frame_width  = 2)

f_conf_col(float c) =>
    c >= 75 ? col_bull : c >= 55 ? col_warn : col_bear

if barstate.islast
    // Header
    table.cell(t, 0, 0, "TF",        text_color = color.white, text_size = size.small, bgcolor = color.new(#1E293B, 0))
    table.cell(t, 1, 0, "CONF.",     text_color = color.white, text_size = size.small, bgcolor = color.new(#1E293B, 0))
    table.cell(t, 2, 0, "LIVE",      text_color = color.white, text_size = size.small, bgcolor = color.new(#1E293B, 0))
    table.cell(t, 3, 0, "ALIGN",     text_color = color.white, text_size = size.small, bgcolor = color.new(#1E293B, 0))
    table.cell(t, 4, 0, "SCORE",     text_color = color.white, text_size = size.small, bgcolor = color.new(#1E293B, 0))

    // Row W
    table.cell(t, 0, 1, "W",                                text_color = color.new(#94A3B8, 10), text_size = size.small)
    table.cell(t, 1, 1, conf_bias_w,                        text_color = f_col(conf_bias_w),     text_size = size.small)
    table.cell(t, 2, 1, live_bias_w,                        text_color = f_col(live_bias_w),     text_size = size.small)
    table.cell(t, 3, 1, star_w,                             text_color = color.white,             text_size = size.small)
    table.cell(t, 4, 1, str.tostring(math.round(conf_w)) + "%", text_color = f_conf_col(conf_w),  text_size = size.small)

    // Row D
    table.cell(t, 0, 2, "D",                                text_color = color.new(#94A3B8, 10), text_size = size.small)
    table.cell(t, 1, 2, conf_bias_d,                        text_color = f_col(conf_bias_d),     text_size = size.small)
    table.cell(t, 2, 2, live_bias_d,                        text_color = f_col(live_bias_d),     text_size = size.small)
    table.cell(t, 3, 2, star_d,                             text_color = color.white,             text_size = size.small)
    table.cell(t, 4, 2, str.tostring(math.round(conf_d)) + "%", text_color = f_conf_col(conf_d),  text_size = size.small)

    // Row H4
    table.cell(t, 0, 3, "H4",                               text_color = color.new(#94A3B8, 10), text_size = size.small)
    table.cell(t, 1, 3, conf_bias_h4,                       text_color = f_col(conf_bias_h4),    text_size = size.small)
    table.cell(t, 2, 3, live_bias_h4,                       text_color = f_col(live_bias_h4),    text_size = size.small)
    table.cell(t, 3, 3, star_h4,                            text_color = color.white,             text_size = size.small)
    table.cell(t, 4, 3, str.tostring(math.round(conf_h4)) + "%", text_color = f_conf_col(conf_h4), text_size = size.small)

    // Row H1
    table.cell(t, 0, 4, "H1",                               text_color = color.new(#94A3B8, 10), text_size = size.small)
    table.cell(t, 1, 4, conf_bias_h1,                       text_color = f_col(conf_bias_h1),    text_size = size.small)
    table.cell(t, 2, 4, live_bias_h1,                       text_color = f_col(live_bias_h1),    text_size = size.small)
    table.cell(t, 3, 4, star_h1,                            text_color = color.white,             text_size = size.small)
    table.cell(t, 4, 4, str.tostring(math.round(conf_h1)) + "%", text_color = f_conf_col(conf_h1), text_size = size.small)

    // Row M15
    table.cell(t, 0, 5, "M15",                              text_color = color.new(#94A3B8, 10), text_size = size.small)
    table.cell(t, 1, 5, conf_bias_m15,                      text_color = f_col(conf_bias_m15),   text_size = size.small)
    table.cell(t, 2, 5, live_bias_m15,                      text_color = f_col(live_bias_m15),   text_size = size.small)
    table.cell(t, 3, 5, star_m15,                           text_color = color.white,             text_size = size.small)
    table.cell(t, 4, 5, str.tostring(math.round(conf_m15)) + "%", text_color = f_conf_col(conf_m15), text_size = size.small)

    // Summary : HTF alignment row (W + D + H4)
    _all_bull = live_bias_w == "BULL" and live_bias_d == "BULL" and live_bias_h4 == "BULL"
    _all_bear = live_bias_w == "BEAR" and live_bias_d == "BEAR" and live_bias_h4 == "BEAR"
    _htf_txt = _all_bull ? "🟢 ALIGNED BULL" : _all_bear ? "🔴 ALIGNED BEAR" : "⚠️ MIXED"
    _htf_col = _all_bull ? col_bull : _all_bear ? col_bear : col_warn
    _avg_conf = math.round((conf_w + conf_d + conf_h4) / 3)

    table.cell(t, 0, 6, "HTF W+D+H4", text_color = color.white, text_size = size.small, bgcolor = color.new(#1E293B, 0))
    table.cell(t, 1, 6, _htf_txt,     text_color = _htf_col,     text_size = size.small, bgcolor = color.new(#1E293B, 0))
    table.cell(t, 2, 6, "",           bgcolor = color.new(#1E293B, 0))
    table.cell(t, 3, 6, "",           bgcolor = color.new(#1E293B, 0))
    table.cell(t, 4, 6, str.tostring(_avg_conf) + "%", text_color = f_conf_col(_avg_conf), text_size = size.small, bgcolor = color.new(#1E293B, 0))

    // Time-in-candle row (how much of each candle is already done)
    table.cell(t, 0, 7, "TIME %",     text_color = color.new(#94A3B8, 10), text_size = size.tiny, bgcolor = color.new(#1E293B, 0))
    table.cell(t, 1, 7, "W:" + str.tostring(math.round(elapsed_w)) + "%",     text_color = color.new(#94A3B8, 10), text_size = size.tiny, bgcolor = color.new(#1E293B, 0))
    table.cell(t, 2, 7, "D:" + str.tostring(math.round(elapsed_d)) + "%",     text_color = color.new(#94A3B8, 10), text_size = size.tiny, bgcolor = color.new(#1E293B, 0))
    table.cell(t, 3, 7, "H4:" + str.tostring(math.round(elapsed_h4)) + "%",   text_color = color.new(#94A3B8, 10), text_size = size.tiny, bgcolor = color.new(#1E293B, 0))
    table.cell(t, 4, 7, "H1:" + str.tostring(math.round(elapsed_h1)) + "%",   text_color = color.new(#94A3B8, 10), text_size = size.tiny, bgcolor = color.new(#1E293B, 0))

// ── ALERTS ──────────────────────────────────────────────────────────
alertcondition(
     conf_d >= 80 and live_bias_d == "BULL" and live_bias_d != live_bias_d[1],
     "Daily STRONG BULL (>80%)",
     "ICT Bias v3 : Daily BULL with 80%+ confidence on {{ticker}}")

alertcondition(
     conf_d >= 80 and live_bias_d == "BEAR" and live_bias_d != live_bias_d[1],
     "Daily STRONG BEAR (>80%)",
     "ICT Bias v3 : Daily BEAR with 80%+ confidence on {{ticker}}")

alertcondition(
     live_bias_w == "BULL" and live_bias_d == "BULL" and live_bias_h4 == "BULL" and
     (live_bias_w[1] != "BULL" or live_bias_d[1] != "BULL" or live_bias_h4[1] != "BULL"),
     "W+D+H4 ALL BULL aligned",
     "ICT Bias v3 : W+D+H4 all BULL on {{ticker}}")

alertcondition(
     live_bias_w == "BEAR" and live_bias_d == "BEAR" and live_bias_h4 == "BEAR" and
     (live_bias_w[1] != "BEAR" or live_bias_d[1] != "BEAR" or live_bias_h4[1] != "BEAR"),
     "W+D+H4 ALL BEAR aligned",
     "ICT Bias v3 : W+D+H4 all BEAR on {{ticker}}")

// End ───────────────────────────────────────────────────────────────
